"guide.section.camouflage" = "CAMOUFLAGE";
"guide.fakehome.title" = "Fake Home Screen";
"guide.fakehome.subtitle" = "Show a home screen screenshot when Performance opens";
"guide.fakehome.help.what.title" = "What is Fake Home Screen?";
"guide.fakehome.help.what.body" = "When you open Performance, instead of going straight to your profile, the app first shows a screenshot of your real iPhone home screen. To an observer it looks like you just opened the Instagram app normally.";
"guide.fakehome.help.how.title" = "How to use it";
"guide.fakehome.help.how.body" = "1. Take a real screenshot of your iPhone home screen making sure the Instagram icon is visible.\n\n2. Upload it in Settings › Other › Fake Home Screen.\n\n3. Enable the toggle.\n\n4. Next time you open Performance, that screenshot appears full screen — tap anywhere (ideally right on the Instagram icon) to reveal your profile.";
"guide.fakehome.help.why.title" = "Why use it?";
"guide.fakehome.help.why.body" = "It creates the illusion that you are simply opening the real Instagram app. Anyone looking at your screen only sees the normal home screen before your profile appears.";
"guide.lockscreen.title" = "Lockscreen Input";
"guide.lockscreen.subtitle" = "Fake iOS lockscreen for secret digit entry";
"guide.lockscreen.help.what.title" = "What is Lockscreen Input?";
"guide.lockscreen.help.what.body" = "When you open Performance, the app shows a fake iOS-style passcode screen before revealing your profile. To anyone watching it looks like you are simply unlocking your phone.";
"guide.lockscreen.help.how.title" = "How to enter your secret number";
"guide.lockscreen.help.how.body" = "1. Tap the digits of your secret number on the numpad — they register silently.\n\n2. Tap anywhere outside the numpad to lock those digits in place.\n\n3. Fill the remaining dots by tapping any digits — they are ignored.\n\n4. Once all 4 dots are filled the lockscreen dismisses and Performance opens.";
"guide.lockscreen.help.wallpaper.title" = "Wallpaper";
"guide.lockscreen.help.wallpaper.body" = "Upload the same wallpaper you use on your real lock screen so the fake one looks identical. Without a wallpaper the lockscreen input cannot be enabled.";
"guide.lockscreen.help.why.title" = "Why use it?";
"guide.lockscreen.help.why.body" = "It disguises the act of entering a secret number as a normal phone unlock. Combined with Fake Home Screen, the full sequence looks like: unlock phone → home screen → open Instagram.";
"guide.lockscreen.help.tricks.title" = "Same secret number — many tricks";
"guide.lockscreen.help.tricks.body" = "The number you enter here is the same secret number used by the Grid Input and all other magic tricks. With it you can trigger:\n\n• Unarchive a photo from a numeric set\n• Reveal a playing card\n• Show a custom image\n• Activate counter glitch\n• Force a reel in Explore";
"guide.lockscreen.help.cards.title" = "รหัสไพ่";
"guide.lockscreen.help.cards.body" = "เพื่อเปิดเผยไพ่ ให้ป้อนรหัสเป็นตัวเลขลับ:\n\nดอก:  1 = ♠   2 = ♥   3 = ♣   4 = ♦\n\nไพ่ A–9  →  [ค่า][ดอก]\n  A♠ = 11    7♥ = 72    9♦ = 94\n\nไพ่ 10, J, Q, K  →  [หลักสิบ][หลักหน่วย][ดอก]\n  10♠ = 101    J♥ = 112\n  Q♣  = 123    K♦  = 134\n\nตัวอย่าง: เปิดเผย Q♥ ให้ป้อน 122";

