"guide.amnesia.row.title" = "Amnesia Carousel";
"guide.amnesia.row.subtitle" = "เอฟเฟกต์ความจำสะกดจิต — ซ่อนรูปที่ 5 แล้วเปิดเผยบน Instagram";
"guide.amnesia.hero_subtitle" = "เอฟเฟกต์ความจำสะกดจิต · ยืนยันบน Instagram";
"guide.amnesia.what.title" = "นี่คืออะไร?";
"guide.amnesia.what.body" = "เอฟเฟกต์ความจำลืมเลือนด้วยการสะกดจิตที่ยืนยันได้บน Instagram จริง คุณอัพโหลดรูปคาร์รูเซล 5 รูป แต่แรกเริ่มจะเห็นเพียง 4 รูป ผู้ชมจำรูปได้แล้วปิด Instagram และคุณเปิดใช้ทริกเกอร์จากแอป เมื่อเขาเปิด Instagram อีกครั้งจะเห็น 5 รูป — พร้อมวันที่อัพโหลดเดิม";
"guide.amnesia.trigger.title" = "ทริกเกอร์";
"guide.amnesia.trigger.body" = "เมื่อเปิดและปิดคาร์รูเซลในแอป คำสั่งจะถูกเปิดใช้งานโดยอัตโนมัติ\n\n⚡ ลำดับที่ถูกต้อง:\n1. ผู้ชมเปิด Instagram และดู 4 รูป + วันที่\n2. ผู้ชมปิด Instagram\n3. คุณเปิดและปิดคาร์รูเซลในแอป → ทริกเกอร์เปิดใช้\n4. ผู้ชมเปิด Instagram อีกครั้ง → 5 รูป วันที่เดิม\n\n❌ ถ้าเปิดทริกเกอร์ก่อนผู้ชมดูคาร์รูเซล เขาจะเห็น 5 รูปโดยตรงและเอฟเฟกต์จะไม่ทำงาน";
"guide.amnesia.hidden.title" = "รูปที่ซ่อนอยู่";
"guide.amnesia.hidden.body" = "รูปที่ 5 (ทำเครื่องหมายด้วยขอบสีส้มในแอป) คือรูปที่เก็บถาวรบน Instagram ตั้งแต่แรก ผู้ชมไม่เห็นมันในการดูครั้งแรก — จะปรากฏเฉพาะในการยืนยันขั้นสุดท้าย";
"guide.amnesia.options.title" = "สองวิธีในการเปิดใช้ทริกเกอร์";
"guide.amnesia.optionA.title" = "ท่ามือ (ดราม่ามากกว่า)";
"guide.amnesia.optionA.body" = "ผู้ชมปิด Instagram คุณพูดว่า 'ฉันปิดด้วย' และปิดคาร์รูเซลในแอปดัง ๆ เมื่อผู้ชมหลับตา คุณทำท่ามือในขณะพูด การสลับเกิดขึ้นในพื้นหลังโดยไม่มีใครเห็น";
"guide.amnesia.optionB.title" = "การเลื่อนแบบลับ (ล่องหนกว่า)";
"guide.amnesia.optionB.body" = "ขณะผู้ชมฟังคำพูดเรื่องความทรงจำ คุณเลื่อนแอปอย่างสบาย ๆ และปิดคาร์รูเซลโดยไม่พูดอะไร ผู้ชมไม่เชื่อมโยงท่าทางนั้นกับเอฟเฟกต์";
"guide.amnesia.date.title" = "การยืนยันด้วยวันที่ — ฝ่ายสุดท้าย";
"guide.amnesia.date.body" = "ตั้งแต่ต้น ขอให้ผู้ชมสังเกตวันที่อัพโหลดของโพสต์ ในตอนท้ายเมื่อเขาเห็น 5 รูป คุณถาม:\n\n'วันที่เหมือนกับที่เห็นตอนแรกไหม?'\n\nเสมอ — เพราะทั้งสองคาร์รูเซลอัพโหลดพร้อมกัน Instagram ไม่สามารถแก้ไขวันที่ได้ รายละเอียดนี้เปลี่ยนการยืนยันเป็นหลักฐานที่โต้แย้งไม่ได้";
"guide.amnesia.script.title" = "สคริปต์การแสดง";
"guide.amnesia.script.opening.phase" = "เปิดเรื่อง";
"guide.amnesia.script.opening.text" = "'หยิบโทรศัพท์ออกมา เปิด Instagram ของฉันและหาโพสต์นี้ เปิดมัน... ใช้เวลาของคุณ ดูทีละรูป สังเกตวันที่อัพโหลดใต้โพสต์ด้วย จำไว้ — สำคัญมาก จำทุกรูปแล้วหรือยัง? และวันที่? ดี'";
"guide.amnesia.script.close.phase" = "ปิด INSTAGRAM";
"guide.amnesia.script.close.text" = "'ตอนนี้ปิด Instagram ทั้งหมดจาก App Switcher รูปเหล่านี้จะมีอยู่ในใจของคุณเพียงชั่วขณะ ฉันไม่ต้องการให้สิ่งภายนอกใดมีอิทธิพลต่อคุณ ไม่มีใครควรเห็นหน้าจอของคุณ'";
"guide.amnesia.script.optionA.phase" = "ตัวเลือก A — ท่ามือ";
"guide.amnesia.script.optionA.text" = "'ฉันปิดด้วย' [นักมายากลปิดคาร์รูเซลในแอป → การสลับเปิดใช้งาน]\n\n'ตอนนี้เราทั้งคู่ตัดการเชื่อมต่อแล้ว มีเพียงรูปภาพ... ที่นี่' [ชี้ที่ศีรษะ]\n\n[หลับตา] ยื่นมือออก: 'ทุกการเคลื่อนไหว... รูปหนึ่งเลือนหายไป... เหมือนมันไม่เคยอยู่ที่นั่นทั้งหมด' [สามครั้งช้า ๆ]\n\n'เสร็จแล้ว เปิดตาได้'";
"guide.amnesia.script.optionB.phase" = "ตัวเลือก B — การเลื่อนแบบลับ";
"guide.amnesia.script.optionB.text" = "[นักมายากลเลื่อนแอปอย่างสบาย ๆ และปิดคาร์รูเซลขณะพูด]\n\n'ความทรงจำไม่ใช่ภาพถ่าย มันคือการสร้างขึ้นใหม่ ทุกครั้งที่คุณจำอะไร จิตใจของคุณเขียนมันใหม่เล็กน้อย ในช่วงที่ไม่เสถียรนั้น... การแทรกแซงเป็นไปได้'\n\n'คุณจำรูปได้กี่รูปกันแน่?' [ผู้ชม: สี่รูป]";
"guide.amnesia.script.climax.phase" = "จุดสูงสุด";
"guide.amnesia.script.climax.text" = "'เปิด Instagram อีกครั้ง หาโพสต์เดิม'\n\n[ผู้ชมเห็น 5 รูป]\n\n'เห็นกี่รูป?' — ห้ารูป\n\n'ดูวันที่ เหมือนกับก่อนหน้าไหม?' — ใช่\n\n'Instagram ไม่โกหก มันไม่สามารถแก้ไขวันที่ได้ มันถูกอัพโหลดแบบนี้'\n\n[หยุด]\n\n'สิ่งที่เกิดขึ้นไม่ใช่คุณลืมรูป จิตใจของคุณถูกนำทางให้ไม่มองเห็นมัน และตอนนี้คุณรู้แล้วว่าสิ่งนั้นเป็นไปได้'";
