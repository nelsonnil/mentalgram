// ── Limits & Safety help (simplified) ──
"limits.help.title" = "Limiti e sicurezza";

"limits.help.calm.title" = "Tranquillo — è tutto sotto controllo";
"limits.help.calm.body" = "Instagram mostra ogni tanto un breve avviso chiedendo di confermare che sei tu. È del tutto normale per qualsiasi app connessa alla piattaforma e non ha nulla a che fare con un ban. Vault è progettata con le stesse protezioni anti-bot usate dalle app reali, e ognuna è stata testata a fondo.";
"limits.help.calm.infobox" = "Personalmente ho attivato questo tipo di avviso più di 100 volte durante lo sviluppo e il mio account non è mai stato bannato. Altre app con lo stesso approccio funzionano senza problemi — se ci fosse un rischio reale, Vault non sarebbe pubblicata.";

"limits.help.warning.title" = "Se compare un avviso di \"Attività insolita\"";
"limits.help.warning.intro" = "Nessun problema — non è un ban. È solo Instagram che conferma che sei davvero tu. Segui questi passaggi:";
"limits.help.warning.step1" = "Apri l'app ufficiale di Instagram e tocca \"Dismiss\" sull'avviso.";
"limits.help.warning.step2" = "Se richiede una verifica, completala con il codice via email o SMS.";
"limits.help.warning.step3" = "In Vault, esci dall'account dalle Impostazioni, aspetta circa un minuto e rientra.";
"limits.help.warning.step4" = "Pronto per continuare — il tuo account è al sicuro.";
"limits.help.warning.reassure" = "Il tuo account continua a funzionare perfettamente. Questo mette in pausa Vault solo per qualche minuto, nulla di più.";

"limits.help.show.title" = "Durante uno spettacolo";
"limits.help.show.body" = "Se compare un avviso mentre lo spettatore sta guardando lo schermo, Vault nasconde tutti i dettagli tecnici e mostra una schermata generica \"Nessuna connessione Internet\".";
"limits.help.show.infobox" = "Scusa perfetta: \"Uff, Instagram fa i capricci un attimo, niente di importante.\" Nessuno spettatore vedrà nulla di tecnico.";

"limits.help.best.title" = "Buone pratiche";
"limits.help.best.item1" = "Non ripetere lo stesso effetto più volte di seguito nella stessa sessione — l'algoritmo potrebbe segnalarlo come automatizzato.";
"limits.help.best.item2" = "Prepara i tuoi set (Sync & Archive) la sera prima o almeno un'ora prima dello spettacolo, non subito dopo aver provato.";
"limits.help.best.item3" = "Se ti esibisci spesso, usa un account Instagram dedicato, separato da quello principale.";
"limits.help.best.item4" = "Vault gestisce automaticamente tutti i tempi di attesa — non devi pensarci.";

// ── Guide: Camouflage section ──
"guide.section.camouflage" = "MIMETISMO";
"guide.fakehome.title" = "Schermata Home Falsa";
"guide.fakehome.subtitle" = "Mostra uno screenshot della home all'apertura di Performance";
"guide.fakehome.help.what.title" = "Cos'è la schermata home falsa?";
"guide.fakehome.help.what.body" = "Aprendo Performance, invece di andare direttamente al profilo, l'app mostra prima uno screenshot della tua vera schermata home iPhone. Per un osservatore sembrerà che tu stia semplicemente aprendo Instagram.";
"guide.fakehome.help.how.title" = "Come usarla";
"guide.fakehome.help.how.body" = "1. Fai uno screenshot reale della tua schermata home con l'icona Instagram visibile.\n\n2. Caricalo in Impostazioni › Altro › Schermata Home Falsa.\n\n3. Attiva l'interruttore.\n\n4. La prossima volta che apri Performance, quello screenshot appare a schermo intero — tocca ovunque (idealmente sull'icona Instagram) per rivelare il tuo profilo.";
"guide.fakehome.help.why.title" = "Perché usarla?";
"guide.fakehome.help.why.body" = "Crea l'illusione che tu stia semplicemente aprendo la vera app Instagram. Chiunque guardi il tuo schermo vedrà solo la normale schermata home prima che appaia il tuo profilo.";
"guide.lockscreen.title" = "Inserimento tramite schermata di blocco";
"guide.lockscreen.subtitle" = "Falsa schermata di blocco iOS per l'inserimento segreto di cifre";
"guide.lockscreen.help.what.title" = "Cos'è l'inserimento tramite schermata di blocco?";
"guide.lockscreen.help.what.body" = "Aprendo Performance, l'app mostra una falsa schermata codice in stile iOS. Per qualsiasi osservatore sembrerà che tu stia semplicemente sbloccando il telefono.";
"guide.lockscreen.help.how.title" = "Come inserire il tuo numero segreto";
"guide.lockscreen.help.how.body" = "1. Tocca le cifre del tuo numero segreto sul tastierino — vengono registrate in silenzio.\n\n2. Tocca fuori dal tastierino per bloccare quelle cifre.\n\n3. Riempi i punti rimanenti con qualsiasi cifra — vengono ignorati.\n\n4. Una volta riempiti tutti e 4 i punti, la schermata di blocco si chiude e si apre Performance.";
"guide.lockscreen.help.wallpaper.title" = "Sfondo";
"guide.lockscreen.help.wallpaper.body" = "Carica lo stesso sfondo che usi sulla tua vera schermata di blocco per renderla identica. Senza sfondo l'inserimento tramite schermata di blocco non può essere attivato.";
"guide.lockscreen.help.why.title" = "Perché usarla?";
"guide.lockscreen.help.why.body" = "Maschera l'inserimento di un numero segreto come normale sblocco del telefono. Combinato con la schermata home falsa, la sequenza completa sembra: sblocca → home → apri Instagram.";
"guide.lockscreen.help.tricks.title" = "Lo stesso numero segreto — tanti trucchi";
"guide.lockscreen.help.tricks.body" = "Il numero inserito qui è lo stesso usato dall'inserimento a griglia e da tutti gli altri trucchi:\n\n• Disarchiviare una foto da un set numerico\n• Rivelare una carta da gioco\n• Mostrare un'immagine personalizzata\n• Attivare l'effetto contatore\n• Forzare un reel in Esplora";
"guide.lockscreen.help.cards.title" = "Codici delle carte";
"guide.lockscreen.help.cards.body" = "Per rivelare una carta, inserisci il suo codice come numero segreto:\n\nSemi:  1 = ♠   2 = ♥   3 = ♣   4 = ♦\n\nCarte A–9  →  [valore][seme]\n  A♠ = 11    7♥ = 72    9♦ = 94\n\nCarte 10, J, Q, K  →  [decina][unità][seme]\n  10♠ = 101    J♥ = 112\n  Q♣  = 123    K♦  = 134\n\nEsempio: per rivelare Q♥ inserisci 122.";

