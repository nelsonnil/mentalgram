"guide.amnesia.row.title" = "Amnesia Carousel";
"guide.amnesia.row.subtitle" = "Effetto di amnesia ipnotica — nascondi una 5ª immagine, rivelala su Instagram";
"guide.amnesia.hero_subtitle" = "Effetto di amnesia ipnotica · Verificato su Instagram";
"guide.amnesia.what.title" = "Cos'è?";
"guide.amnesia.what.body" = "Un effetto di amnesia ipnotica con verifica su Instagram reale. Carichi un carosello di 5 immagini, ma inizialmente ne sono visibili solo 4. Lo spettatore le memorizza, chiude Instagram e tu attivi il TRIGGER dalla tua app. Quando riapre Instagram vede 5 immagini — con la stessa data di caricamento originale.";
"guide.amnesia.trigger.title" = "Il trigger";
"guide.amnesia.trigger.body" = "Aprendo il carosello nella tua app e chiudendolo, si attiva automaticamente un comando che cambia il carosello visibile su Instagram reale.\n\n⚡ ORDINE CORRETTO:\n1. Lo spettatore apre Instagram e vede 4 immagini + data.\n2. Lo spettatore chiude Instagram.\n3. Tu apri e chiudi il carosello nella tua app → trigger attivato.\n4. Lo spettatore riapre Instagram → 5 immagini, stessa data.\n\n❌ Se attivi il trigger PRIMA che lo spettatore abbia visto il carosello, vedrà direttamente 5 immagini e l'effetto non funziona.";
"guide.amnesia.hidden.title" = "Immagine nascosta";
"guide.amnesia.hidden.body" = "La 5ª immagine (contrassegnata con un bordo arancione nell'app) è quella inizialmente archiviata su Instagram. Lo spettatore non la vede mai nella prima visualizzazione — appare solo nella verifica finale.";
"guide.amnesia.options.title" = "Due modi per attivare il trigger";
"guide.amnesia.optionA.title" = "Passate di mani (più teatrale)";
"guide.amnesia.optionA.body" = "Lo spettatore chiude Instagram. Tu dici «Chiudo anch'io» e chiudi il carosello nella tua app ad alta voce — come un gesto simmetrico del rituale. Con gli occhi dello spettatore chiusi, fai passate di mani mentre parli. Lo swap avviene in background senza che nessuno lo veda.";
"guide.amnesia.optionB.title" = "Scorrimento discreto (più invisibile)";
"guide.amnesia.optionB.body" = "Mentre lo spettatore ascolta il tuo discorso sulla memoria, scorri casualmente nella tua app e chiudi il carosello senza dire nulla. Lo spettatore non collega quel gesto all'effetto. Funziona molto bene in gruppo dove nessuno guarda il tuo schermo.";
"guide.amnesia.date.title" = "Verifica con la data — il colpo finale";
"guide.amnesia.date.body" = "All'inizio chiedi allo spettatore di notare la data di caricamento del post. Alla fine, quando vede 5 immagini, chiedi:\n\n«È la stessa data che hai visto prima?»\n\nLo è sempre — perché entrambi i caroselli sono stati caricati contemporaneamente. Instagram non può modificare le date. Questo dettaglio trasforma la verifica in prova inconfutabile.";
"guide.amnesia.script.title" = "Copione di performance";
"guide.amnesia.script.opening.phase" = "APERTURA";
"guide.amnesia.script.opening.text" = "«Prendi il tuo telefono. Apri il mio Instagram e trova questo post. Aprilo... prenditi il tuo tempo. Guarda ogni immagine, una per una. Nota anche la data di caricamento sotto il post. Memorizzala — è importante. Le hai tutte? E la data? Bene.»";
"guide.amnesia.script.close.phase" = "CHIUSURA DI INSTAGRAM";
"guide.amnesia.script.close.text" = "«Ora chiudi Instagram completamente dal multitasking. Queste immagini esisteranno solo nella tua mente per qualche istante. Non voglio che nulla di esterno possa influenzarti. Nessuno deve poter vedere il tuo schermo.»";
"guide.amnesia.script.optionA.phase" = "OPZIONE A — PASSATE DI MANI";
"guide.amnesia.script.optionA.text" = "«Chiudo anch'io.» [Il mago chiude il carosello nell'app → swap attivato]\n\n«Ora siamo entrambi disconnessi. Restano solo le immagini... qui.» [Indica la testa]\n\n[Occhi chiusi] Mano tesa: «Ad ogni movimento... un'immagine diventa meno nitida... come se non fosse mai stata del tutto lì.» [Tre passate lente]\n\n«Fatto. Puoi aprire gli occhi.»";
"guide.amnesia.script.optionB.phase" = "OPZIONE B — SCORRIMENTO DISCRETO";
"guide.amnesia.script.optionB.text" = "[Il mago scorre casualmente nell'app e chiude il carosello mentre parla]\n\n«La memoria non è una fotografia. È una ricostruzione. Ogni volta che ricordi qualcosa, la tua mente lo riscrive leggermente. In quell'istante... è possibile intervenire.»\n\n«Quante immagini ricordi esattamente?» [Spettatore: quattro]";
"guide.amnesia.script.climax.phase" = "CLIMAX";
"guide.amnesia.script.climax.text" = "«Riapri Instagram. Cerca lo stesso post.»\n\n[Lo spettatore vede 5 immagini]\n\n«Quante ne vedi?» — Cinque.\n\n«Guarda la data. È la stessa di prima?» — Sì.\n\n«Instagram non mente. Non può modificare le date. È stato caricato così.»\n\n[Pausa]\n\n«Quello che è successo non è che hai dimenticato un'immagine. La tua mente è stata guidata a non vederla. E ora sai che questo è possibile.»";
