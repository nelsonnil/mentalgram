"postpred.help.howitworks.step1" = "Prepara il tuo **Set** — carica le foto in anticipo e lascia che l'app le archivi automaticamente. Diventano invisibili su Instagram finché non scegli di rivelarle.";
"postpred.help.howitworks.step2" = "Lo spettatore sceglie liberamente una parola, un numero, un'immagine o una carta. Catturi la sua scelta silenziosamente con uno dei metodi di input.";
"postpred.help.howitworks.step3" = "Attiva la rivelazione. La foto corrispondente riappare su Instagram reale **nella sua posizione originale, con la sua data originale** — come se fosse sempre stata lì.";
"postpred.help.howitworks.body1" = "Prepari un **Set** di foto, una per ogni lettera o cifra. Le foto vengono caricate in anticipo e archiviate automaticamente, quindi invisibili su Instagram fino a quando non scegli di rivelarle.";
"postpred.help.howitworks.body2" = "Quando attivi la rivelazione, l'app dearchivia la foto corrispondente. Riappare nella sua **posizione originale nella griglia**, con la sua **data originale**, come se fosse sempre stata li.";
"postpred.help.howitworks.info" = "Lo spettatore vede un post reale su un profilo Instagram reale. Nessuna app e visibile, solo Instagram.";
"postpred.help.metric.sets" = "Set";
"postpred.help.metric.sets.desc" = "Raccolte di foto (lettere A-Z o cifre 0-9) caricate e archiviate in anticipo, pronte per essere rivelate.";
"postpred.help.metric.banks" = "Banche";
"postpred.help.metric.banks.desc" = "Ogni banca = una posizione nella parola o nel numero. Banca 1 -> prima lettera, Banca 2 -> seconda lettera, ecc. Il numero di banche definisce la lunghezza massima di cio che puoi rivelare.";
"postpred.help.inputs.body1" = "Lo spettatore pensa liberamente a una parola o un numero. Catturi la sua scelta silenziosamente usando uno dei tre metodi:";
"postpred.help.inputs.intro" = "Ogni metodo di input è compatibile con tipi di set specifici. Scegli quello più adatto alla tua performance.";
"postpred.help.input.grid.label" = "INPUT A GRIGLIA";
"postpred.help.input.grid.intro" = "In Performance, scorri a sinistra o destra sulla griglia foto. I post 1–9 corrispondono alle cifre 1–9; i post 10+ corrispondono alla cifra 0. Accumula fino a 3 cifre, poi tocca l'icona Posts per rivelare.";
"postpred.help.input.grid.case.number" = "Ogni cifra seleziona lo slot nella sua banca — banca 1 → 1a cifra, banca 2 → 2a cifra, ecc.";
"postpred.help.input.grid.case.custom" = "Tutte le cifre accumulate formano il numero di slot (1–100). Es: scorri 7 poi 2 = slot 72. Scorri 1, 0, 0 = slot 100.";
"postpred.help.input.grid.case.card" = "2 cifre: [valore + seme]. 3 cifre: [decina + unità + seme]. Semi: 1=♠  2=♥  3=♣  4=♦. Es: 4→2 = 4♥ · 1→1→1 = J♠.";
"postpred.help.input.grid.step1" = "Abilita **Griglia cifre** nelle impostazioni di Post Prediction.";
"postpred.help.input.grid.step2" = "In Performance, scorri a sinistra o destra sulla griglia foto. I post 1-9 corrispondono alle cifre 1-9. I post 10, 11 e 12 corrispondono alla cifra 0. Un indicatore mostra il numero accumulato.";
"postpred.help.input.grid.step3" = "Tocca l'icona Posts per confermare e attivare la rivelazione.";
"postpred.help.input.ocr.label" = "OCR — FOTOCAMERA";
"postpred.help.input.covert.label" = "DIGITAZIONE NASCOSTA";
"postpred.help.input.covert.step1" = "Attiva **Digitazione Nascosta** nelle impostazioni e definisci una parola di copertura — ciò che il pubblico vedrà a schermo.";
"postpred.help.input.covert.step2" = "Digita la parola dello spettatore nel campo di ricerca di Explore. Lo spettatore vede la parola di copertura; l'app registra silenziosamente quella reale.";
"postpred.help.input.covert.step3" = "Premi **Spazio una sola volta** quando hai finito. Lo spazio scompare dal campo — è normale. Una leggera vibrazione conferma che la parola è stata catturata e la rivelazione attivata.";
"postpred.help.input.url.label" = "URL SCHEME / AUTOMAZIONE";
"postpred.help.input.url.intro" = "Attiva la rivelazione da remoto con qualsiasi strumento di automazione — Comandi di Apple, tag NFC, QR code o app complementari. Compatibile con tutti i tipi di set.";
"postpred.help.input.url.example.word" = "Word Reveal";
"postpred.help.input.url.example.slot" = "Custom Set — numero di slot (1–100)";
"postpred.help.input.url.example.card" = "Playing Cards — simbolo carta (es. J♠, 10♥, K♦)";
"postpred.help.settype.word.desc" = "**26 slot (A–Z) × N banche.** Ogni banca rivela una lettera. Banca 1 = 1a lettera, Banca 2 = 2a lettera.";
"postpred.help.settype.number.desc" = "**10 slot (0–9) × N banche.** Ogni banca rivela una cifra. Banca 1 = 1a cifra, Banca 2 = 2a cifra.";
"postpred.help.settype.custom.desc" = "**1–100 immagini personalizzate, 1 banca.** Scorri 1–3 cifre per selezionare il numero di slot (1–100). Ideale per risultati sportivi, tarocchi o qualsiasi scelta visiva.";
"postpred.help.settype.card.desc" = "**52 slot (A–K × ♠♥♣♦), 1 banca.** Scorri 2 o 3 cifre per selezionare una carta. Semi: 1=♠ 2=♥ 3=♣ 4=♦. Es: 4→2 = 4♥ · 1→1→1 = J♠.";
"postpred.help.input.ocr.step1" = "Abilita **OCR** nelle impostazioni di Post Prediction.";
"postpred.help.input.ocr.step2" = "Punta la fotocamera su una parola scritta a mano o stampata. L'app la legge automaticamente e attiva la rivelazione corrispondente.";
"postpred.help.input.url.label" = "SCHEMA URL";
"postpred.help.input.url.step1" = "Abilita **URL Scheme** nelle impostazioni di Post Prediction.";
"postpred.help.input.url.step2" = "Attiva la rivelazione da remoto tramite un URL personalizzato, utile con tag NFC, codici QR o scorciatoie di automazione.";
"postpred.help.before.1" = "Crea un **Set** nella sezione Sets. Scegli Word Reveal, Number Reveal, Custom Set o Playing Cards. Seleziona un modello di immagine o carica le tue foto.";
"postpred.help.before.2" = "Carica le immagini e aspetta che vengano **archiviate automaticamente**. Questo puo richiedere diverse ore, lascia l'app attiva tutta la notte se necessario.";
"postpred.help.before.3" = "Durante il caricamento, **non usare l'app**, non cambiare rete e non interrompere il processo. Lo schermo rimane acceso automaticamente. Una notifica ti invita a tornare tra un caricamento e l'altro.";
"postpred.help.before.4" = "Imposta il Set caricato come **attivo** nelle impostazioni di Post Prediction.";
