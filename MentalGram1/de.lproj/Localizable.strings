// ── Limits & Safety help (simplified) ──
"limits.help.title" = "Limits & Sicherheit";

"limits.help.calm.title" = "Entspann dich — alles ist unter Kontrolle";
"limits.help.calm.body" = "Instagram zeigt gelegentlich eine kurze Warnung an, die dich bittet zu bestätigen, dass du es bist. Das ist völlig normal für jede App, die mit der Plattform verbunden ist, und hat nichts mit einer Sperrung zu tun. Vault ist mit denselben Anti-Bot-Schutzmaßnahmen ausgestattet, die echte Apps verwenden, und jede einzelne wurde gründlich getestet.";
"limits.help.calm.infobox" = "Ich habe diese Art von Warnung während der Entwicklung persönlich mehr als 100 Mal ausgelöst, und mein Konto wurde nie gesperrt. Andere Apps mit dem gleichen Ansatz funktionieren problemlos — wenn es ein echtes Risiko gäbe, wäre Vault nicht veröffentlicht.";

"limits.help.warning.title" = "Wenn eine Warnung \"Ungewöhnliche Aktivität\" erscheint";
"limits.help.warning.intro" = "Keine Sorge — das ist keine Sperrung. Instagram bestätigt nur, dass du es wirklich bist. Befolge diese Schritte:";
"limits.help.warning.step1" = "Öffne die offizielle Instagram-App und tippe in der Warnung auf \"Dismiss\".";
"limits.help.warning.step2" = "Wenn eine Verifizierung verlangt wird, schließe sie mit dem E-Mail- oder SMS-Code ab.";
"limits.help.warning.step3" = "Melde dich in Vault über Einstellungen ab, warte etwa eine Minute und melde dich erneut an.";
"limits.help.warning.step4" = "Du kannst weitermachen — dein Konto ist sicher.";
"limits.help.warning.reassure" = "Dein Konto funktioniert weiterhin einwandfrei. Das pausiert Vault nur für wenige Minuten, mehr nicht.";

"limits.help.show.title" = "Während einer Vorführung";
"limits.help.show.body" = "Wenn eine Warnung erscheint, während der Zuschauer auf den Bildschirm schaut, verbirgt Vault alle technischen Details und zeigt einen generischen Bildschirm \"Keine Internetverbindung\".";
"limits.help.show.infobox" = "Perfekte Ausrede: \"Ach, Instagram spinnt kurz, nichts Wichtiges.\" Kein Zuschauer wird etwas Technisches sehen.";

"limits.help.best.title" = "Best Practices";
"limits.help.best.item1" = "Wiederhole nicht denselben Effekt mehrmals hintereinander in derselben Sitzung — der Algorithmus könnte es als automatisiert kennzeichnen.";
"limits.help.best.item2" = "Bereite deine Sets (Sync & Archive) am Abend vorher oder mindestens eine Stunde vor der Show vor, nicht direkt nach dem Proben.";
"limits.help.best.item3" = "Wenn du oft auftrittst, nutze ein eigenes Instagram-Konto, getrennt von deinem Hauptkonto.";
"limits.help.best.item4" = "Vault verwaltet alle Wartezeiten automatisch — du musst an nichts davon denken.";

// ── Guide: Camouflage section ──
"guide.section.camouflage" = "TARNUNG";
"guide.fakehome.title" = "Gefälschter Startbildschirm";
"guide.fakehome.subtitle" = "Zeigt einen Screenshot des Startbildschirms beim Öffnen von Performance";
"guide.fakehome.help.what.title" = "Was ist der gefälschte Startbildschirm?";
"guide.fakehome.help.what.body" = "Beim Öffnen von Performance zeigt die App zunächst einen Screenshot deines echten iPhone-Startbildschirms. Für Zuschauer sieht es so aus, als würdest du einfach Instagram öffnen.";
"guide.fakehome.help.how.title" = "So verwendest du es";
"guide.fakehome.help.how.body" = "1. Mache einen echten Screenshot deines Startbildschirms mit sichtbarem Instagram-Symbol.\n\n2. Lade ihn unter Einstellungen › Sonstiges › Gefälschter Startbildschirm hoch.\n\n3. Aktiviere den Schalter.\n\n4. Beim nächsten Öffnen von Performance erscheint der Screenshot im Vollbild — tippe irgendwo (idealerweise auf das Instagram-Symbol), um dein Profil anzuzeigen.";
"guide.fakehome.help.why.title" = "Warum verwenden?";
"guide.fakehome.help.why.body" = "Es erweckt den Eindruck, dass du einfach die echte Instagram-App öffnest. Jeder, der auf deinen Bildschirm schaut, sieht nur den normalen Startbildschirm, bevor dein Profil erscheint.";
"guide.lockscreen.title" = "Sperrbildschirm-Eingabe";
"guide.lockscreen.subtitle" = "Gefälschter iOS-Sperrbildschirm für die geheime Zifferneingabe";
"guide.lockscreen.help.what.title" = "Was ist die Sperrbildschirm-Eingabe?";
"guide.lockscreen.help.what.body" = "Beim Öffnen von Performance zeigt die App einen gefälschten iOS-Passcode-Bildschirm. Für Zuschauer sieht es aus, als würdest du dein Telefon entsperren.";
"guide.lockscreen.help.how.title" = "So gibst du deine geheime Zahl ein";
"guide.lockscreen.help.how.body" = "1. Tippe die Ziffern deiner Geheimzahl auf dem Ziffernfeld — sie werden lautlos registriert.\n\n2. Tippe außerhalb des Ziffernfelds, um diese Ziffern zu sperren.\n\n3. Fülle die verbleibenden Punkte mit beliebigen Ziffern — sie werden ignoriert.\n\n4. Sobald alle 4 Punkte gefüllt sind, schließt sich der Sperrbildschirm und Performance öffnet sich.";
"guide.lockscreen.help.wallpaper.title" = "Hintergrundbild";
"guide.lockscreen.help.wallpaper.body" = "Lade dasselbe Hintergrundbild hoch, das du auf deinem echten Sperrbildschirm verwendest. Ohne Hintergrundbild kann die Sperrbildschirm-Eingabe nicht aktiviert werden.";
"guide.lockscreen.help.why.title" = "Warum verwenden?";
"guide.lockscreen.help.why.body" = "Es tarnt die Eingabe einer Geheimzahl als normale Telefonentsperrung. Kombiniert mit dem gefälschten Startbildschirm sieht die vollständige Abfolge so aus: Telefon entsperren → Startbildschirm → Instagram öffnen.";
"guide.lockscreen.help.tricks.title" = "Dieselbe Geheimzahl — viele Tricks";
"guide.lockscreen.help.tricks.body" = "Die hier eingegebene Zahl ist dieselbe Geheimzahl, die von der Rastereingabe und allen anderen Zaubertricks verwendet wird:\n\n• Foto aus einem numerischen Set dearchivieren\n• Spielkarte enthüllen\n• Benutzerdefiniertes Bild zeigen\n• Zähler-Glitch aktivieren\n• Reel in Entdecken erzwingen";
"guide.lockscreen.help.cards.title" = "Spielkarten-Codes";
"guide.lockscreen.help.cards.body" = "Um eine Spielkarte aufzudecken, gib ihren Code als Geheimzahl ein:\n\nFarben:  1 = ♠   2 = ♥   3 = ♣   4 = ♦\n\nKarten A–9  →  [Wert][Farbe]\n  A♠ = 11    7♥ = 72    9♦ = 94\n\nKarten 10, B, D, K  →  [Zehner][Einer][Farbe]\n  10♠ = 101    B♥ = 112\n  D♣  = 123    K♦  = 134\n\nBeispiel: Um D♥ aufzudecken, gib 122 ein.";

