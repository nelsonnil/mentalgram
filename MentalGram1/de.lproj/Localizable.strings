"How the Instagram emulator works — navigation, profiles and Explore" = "Wie der Instagram-Emulator funktioniert — Navigation, Profile und Erkunden";
"perf.help.overview.title" = "Was ist Performance?";
"perf.help.plus.title" = "Der +-Button — Einstellungen aufrufen";
