"perf.help.bottombar.title" = "Untere Navigationsleiste";
"perf.help.explore.title" = "Erkunden";
"perf.help.realdata.title" = "Echte Instagram-Daten";
"perf.help.overview.body1" = "Performance ist ein integrierter Instagram-Emulator. Er sieht aus und funktioniert wie die echte Instagram-App, läuft aber innerhalb von Vault und ist über die offizielle API direkt mit deinem Instagram-Konto verbunden.";
"perf.help.overview.infobox" = "Alles, was der Zuschauer sieht, sind echte Instagram-Inhalte aus deinem tatsächlichen Konto — Beiträge, Follower, Reels — live von der API abgerufen. Es ist keine Simulation; es ist dein echtes Profil.";
"perf.help.overview.body2" = "Der Zuschauer kann dein Handy halten, ein beliebiges Profil öffnen, frei scrollen und jederzeit echte Instagram-Daten sehen. Vault arbeitet unsichtbar im Hintergrund.";
"perf.help.plus.body" = "Um über Performance auf die Einstellungen zuzugreifen, tippe auf den +-Button oben links in der Kopfleiste — derselben Leiste, die in der Mitte deinen Benutzernamen zeigt. Dies ist der einzige Weg zurück zu den Einstellungen im Performance-Modus.";
"perf.help.plus.infobox" = "Konfiguriere alle deine Tricks (Force Post, Force Reel, Date Force, Counter Glitch usw.) in den Einstellungen vor der Show. Sobald du in Performance bist, nutze den +-Button, um zurückzukehren und bei Bedarf anzupassen.";
"perf.help.plus.mock.label" = "Kopfleiste";
"perf.help.plus.mock.sublabel" = "Tippe + (oben links) um Einstellungen zu öffnen";
"perf.help.profile.followers.title" = "Follower-Zähler — antippbar";
"perf.help.profile.followers.desc" = "Tippe auf den Follower-Zähler, um die vollständige Follower-Liste zu öffnen. Im Date-Force-Modus tippst du auf den Avatar-Kreis, um Zuschauer auszuwählen — eine blaue Zahl (1, 2, 3…) zeigt die Auswahlreihenfolge an. Erste Hälfte = Datumsgruppe, zweite Hälfte = Uhrzeitgruppe. Tippe neben den Kreis, um das Profil dieser Person zu öffnen.";
"perf.help.profile.tabs.title" = "Beiträge / Reels / Markiert-Tabs";
"perf.help.profile.tabs.desc" = "Wechsle zwischen den drei Tabs, um die Beiträge, Reels und markierten Fotos des Profils zu durchsuchen. Tippe auf ein beliebiges Miniaturbild, um es im Vollbild zu sehen.";
"perf.help.profile.refresh.title" = "Zum Aktualisieren ziehen";
"perf.help.profile.refresh.desc" = "Ziehe das Profil nach unten, um es von Instagram neu zu laden und aktuelle Änderungen anzuzeigen (neue Follower, aktualisierte Bio, neu hochgeladene Fotos).";
"perf.help.bottombar.body" = "Die untere Navigationsleiste ahmt Instagrams Oberfläche nach. Die meisten Buttons sind dekorativ — nur die Lupe (Suchen) ist funktional und öffnet Erkunden.";
"perf.help.bottombar.infobox" = "Der Suche/Lupe-Button ist der Hauptweg, um zu Erkunden zu navigieren. Tippe, um zufällige Reels zu durchsuchen und jedes Instagram-Profil nach Benutzername zu suchen.";
"perf.help.mock.home" = "Start";
"perf.help.mock.search" = "Suchen";
"perf.help.mock.send" = "Senden";
"perf.help.mock.profile" = "Profil";
"perf.help.mock.active" = "✓ Aktiv";
"perf.help.mock.posts" = "Beiträge";
"perf.help.mock.reels" = "Reels";
"perf.help.mock.tagged" = "Markiert";
"perf.help.explore.body" = "Die Erkunden-Ansicht öffnet sich, wenn du die Lupe in der unteren Leiste antippst. Sie zeigt einen echten Instagram-Erkunden-Feed mit zufälligen Reels und eine Suchleiste oben, um jedes Profil zu finden.";
"perf.help.explore.reels.title" = "Zufälliger Reels-Feed";
"perf.help.explore.reels.desc" = "Erkunden zeigt echte Reels von Instagram. Der Zuschauer kann frei scrollen. Im Force-Reel-Modus erscheint das Ziel-Reel an der Position, die du heimlich gewählt hast.";
"perf.help.explore.search.title" = "Jedes echte Profil suchen";
"perf.help.explore.search.desc" = "Gib einen beliebigen Benutzernamen in die Suchleiste ein, um sein echtes Instagram-Profil zu laden — Fotos, Follower, Folgende — direkt von der API. Der Zuschauer kann frei wählen, wen er sich ansieht.";
"perf.help.explore.infobox" = "Im Force-Reel-Modus registriert das Suchen und Wischen zwischen Tabs (Beiträge/Reels/Markiert) auf einem Profil heimlich jede Ziffer der Nummer des Zuschauers. Wenn du Erkunden öffnest, erscheint das Reel genau an dieser Position.";
"perf.help.realdata.body" = "Da Performance mit der echten Instagram-API verbunden ist, sind alle angezeigten Daten authentisch und aktuell. Es gibt keine vorgeladenen Inhalte.";
"perf.help.realdata.item1" = "Fotos und Videos werden live von deinem echten Instagram-Konto geladen";
"perf.help.realdata.item2" = "Follower- und Folgezahlen sind real — und können heimlich für Effekte manipuliert werden";
"perf.help.realdata.item3" = "Jedes Profil, das du suchst, lädt seine echten Beiträge, Reels und Biografie von der API";
