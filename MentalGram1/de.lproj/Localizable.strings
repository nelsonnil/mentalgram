"postpred.help.hero.title" = "Die Bildvorhersage";
"postpred.help.hero.body" = "Ein ausgewahltes Bild erscheint in Echtzeit auf Ihrem Instagram-Profil an seiner exakten ursprunglichen Position, mit dem ursprunglichen Datum, vom Zuschauer gewahlt.";
"postpred.help.section.howitworks" = "So funktioniert es";
"postpred.help.section.inputs" = "Eingabemethoden";
