// Post Prediction Help
"postpred.help.nav.title" = "Post Prediction";
"postpred.help.nav.subtitle" = "Performance-Leitfaden";
"postpred.help.hero.title" = "Die Bildvorhersage";
"postpred.help.hero.body" = "Ein ausgewahltes Bild erscheint in Echtzeit auf Ihrem Instagram-Profil an seiner exakten ursprunglichen Position, mit dem ursprunglichen Datum, vom Zuschauer gewahlt.";
"postpred.help.section.howitworks" = "So funktioniert es";
"postpred.help.section.inputs" = "Eingabemethoden";
"postpred.help.section.before" = "Vor der Show";
"postpred.help.section.during" = "Wahrend der Show";
"postpred.help.section.tips" = "Tipps";
"postpred.help.howitworks.body1" = "Sie bereiten ein **Set** vor, eine Sammlung von Fotos, eines fur jeden Buchstaben oder jede Ziffer. Die Fotos werden im Voraus hochgeladen und automatisch archiviert, sodass sie auf Instagram unsichtbar sind, bis Sie sie enthullen mochten.";
"postpred.help.howitworks.body2" = "Wenn Sie die Enthullung auslosen, dearchiviert die App das entsprechende Foto. Es erscheint an seiner **ursprunglichen Position im Raster**, mit seinem **ursprunglichen Datum**, als ware es immer da gewesen.";
"postpred.help.howitworks.info" = "Der Zuschauer sieht einen echten Beitrag auf einem echten Instagram-Profil. Keine App ist sichtbar, nur Instagram.";
"postpred.help.metric.sets" = "Sets";
"postpred.help.metric.sets.desc" = "Fotosammlungen (Buchstaben A-Z oder Ziffern 0-9), die im Voraus hochgeladen und archiviert wurden und zur Enthullung bereitstehen.";
"postpred.help.metric.banks" = "Banke";
"postpred.help.metric.banks.desc" = "Jede Bank = eine Position im Wort oder in der Zahl. Bank 1 -> erster Buchstabe, Bank 2 -> zweiter Buchstabe usw. Die Anzahl der Banken bestimmt die maximale Lange der Enthullung.";
"postpred.help.inputs.body1" = "Der Zuschauer denkt frei an ein Wort oder eine Zahl. Sie erfassen seine Wahl still mit einer von drei Methoden:";
"postpred.help.input.grid.label" = "RASTEREINGABE";
"postpred.help.input.grid.step1" = "Aktivieren Sie **Ziffernraster** in den Post-Prediction-Einstellungen.";
"postpred.help.input.grid.step2" = "Wischen Sie in Performance links oder rechts uber das Fotoraster. Posts 1-9 entsprechen den Ziffern 1-9. Posts 10, 11 und 12 entsprechen der Ziffer 0. Ein Indikator zeigt die angesammelte Zahl.";
"postpred.help.input.grid.step3" = "Tippen Sie auf das Posts-Symbol, um die Enthullung zu bestatigen und auszulosen.";
"postpred.help.input.ocr.label" = "OCR - KAMERAERKENNUNG";
"postpred.help.input.ocr.step1" = "Aktivieren Sie **OCR** in den Post-Prediction-Einstellungen.";
"postpred.help.input.ocr.step2" = "Richten Sie die Kamera auf ein handgeschriebenes oder gedrucktes Wort. Die App liest es automatisch und lost die entsprechende Enthullung aus.";
"postpred.help.input.url.label" = "URL-SCHEMA";
"postpred.help.input.url.step1" = "Aktivieren Sie **URL Scheme** in den Post-Prediction-Einstellungen.";
"postpred.help.input.url.step2" = "Losen Sie die Enthullung per benutzerdefinierter URL aus, nutzlich mit NFC-Tags, QR-Codes oder Automatisierungsverknupfungen.";
"postpred.help.before.1" = "Erstellen Sie ein **Set** im Sets-Bereich. Wahlen Sie den Buchstabentyp (Numerisch oder Wort) und ein Bildtemplate oder laden Sie eigene Fotos hoch.";
"postpred.help.before.2" = "Laden Sie die Bilder hoch und warten Sie, bis sie **automatisch archiviert** wurden. Dies kann mehrere Stunden dauern, lassen Sie die App bei Bedarf uber Nacht laufen.";
"postpred.help.before.3" = "Wahrend des Uploads **verwenden Sie die App nicht**, wechseln Sie nicht das Netzwerk und unterbrechen Sie den Vorgang nicht. Der Bildschirm bleibt automatisch aktiv. Eine Benachrichtigung fordert Sie auf, zwischen den Uploads zuruckzukehren.";
"postpred.help.before.4" = "Legen Sie das hochgeladene Set als **aktiv** in den Post-Prediction-Einstellungen fest.";
"postpred.help.before.5" = "Aktivieren Sie mindestens eine **Eingabemethode**: Raster, OCR oder URL-Schema.";
"postpred.help.during.step.invite" = "DIE FREIE WAHL";
"postpred.help.during.invite.action" = "Bitten Sie den Zuschauer, frei an ein Wort, eine Zahl oder einen Buchstaben zu denken. Schlagen Sie nichts vor.";
"postpred.help.during.invite.dialogue" = "Denken Sie an ein beliebiges Wort oder eine beliebige Zahl. Etwas Personliches, etwas nur Sie wissen. Sagen Sie es noch nicht.";
"postpred.help.during.step.input" = "DIE WAHL ERFASSEN";
"postpred.help.during.input.action" = "Erfassen Sie die Eingabe still per Raster, OCR oder URL, wahrend der Zuschauer seine Wahl laut ausspricht.";
"postpred.help.during.input.dialogue" = "Sagen Sie es jetzt laut, laut genug, damit alle es horen.";
"postpred.help.during.step.reveal" = "DIE ENTHULLUNG";
"postpred.help.during.reveal.action" = "Die App dearchiviert das passende Foto. In der App erscheint das Ergebnis innerhalb von 2-3 Sekunden. Auf echtem Instagram wird jedes Foto einzeln mit einer kurzen Pause dearchiviert, die Gesamtzeit hangt von der Wortlange ab.";
"postpred.help.during.timing.action" = "Wenn die App vibriert, ist die Enthullung auf echtem Instagram live. Fuhren Sie den Zuschauer zu Instagram.";
"postpred.help.during.timing.dialogue" = "Offnen Sie Instagram. Gehen Sie zu meinem Profil. Scrollen Sie nach unten, es war die ganze Zeit da.";
"postpred.help.tip.timing" = "**Enthullungsgeschwindigkeit.** Ein Buchstabe oder eine Ziffer: ~2-3 Sek. Funf Buchstaben (z. B. MAGIC): ~12-15 Sek. Jeder weitere Buchstabe fugt ~2-3 Sek. hinzu.";
"postpred.help.tip.vibration" = "**Vibration = bereit.** Das haptische Feedback signalisiert, dass das Foto auf echtem Instagram live ist. Fuhren Sie den Zuschauer nach der Vibration.";
"postpred.help.tip.position" = "**Ursprungliche Position.** Das Foto erscheint genau dort, wo es im Raster war, mit seinem ursprunglichen Datum. Moglicherweise muss gescrollt werden.";
"postpred.help.tip.upload" = "**Wahrend des Uploads.** Verwenden Sie die App nicht, wechseln Sie nicht das WLAN-Netz und sperren Sie den Bildschirm nicht. Eine Benachrichtigung fordert Sie auf, zwischen den Uploads zuruckzukehren.";
"postpred.help.tip.banks" = "**Anzahl der Banken.** Jede Bank = eine Buchstaben- oder Ziffernposition. Planen Sie Ihre Sets entsprechend dem langsten Wort oder der langsten Zahl, die Sie enthullen mochten.";
"postpred.help.tip.fakeapp" = "**Fake-Profil = sofortige Vorschau, echtes Instagram = nach der Vibration.** Die Vorhersage erscheint sofort im App-Fake-Profil – aber sie ist noch nicht auf echtem Instagram verfügbar. Warte auf das haptische Feedback, bevor du fortfährst.";
"postpred.help.tip.openprofile" = "**Öffne zuerst dein echtes Instagram-Profil.** Nachdem die Vibration den Upload bestätigt, öffne dein eigenes Instagram-Profil, bevor du den Zuschauer einlädst zu schauen. Dadurch wird der Inhalt im Feed geladen. Wenn der Zuschauer zuerst aktualisiert, muss er möglicherweise nach unten scrollen.";

