"guide.amnesia.row.title" = "Amnesia Carousel";
"guide.amnesia.row.subtitle" = "Hypnotischer Gedächtniseffekt — verstecke ein 5. Bild, enthülle es auf Instagram";
"guide.amnesia.hero_subtitle" = "Hypnotischer Gedächtniseffekt · Instagram-verifiziert";
"guide.amnesia.what.title" = "Was ist das?";
"guide.amnesia.what.body" = "Ein hypnotischer Amnesie-Effekt mit Verifizierung auf echtem Instagram. Du lädst ein Karussell mit 5 Bildern hoch, aber anfangs sind nur 4 sichtbar. Der Zuschauer memoriert sie, schließt Instagram und du aktivierst den AUSLÖSER über deine App. Wenn er Instagram wieder öffnet, sieht er 5 Bilder — mit demselben ursprünglichen Upload-Datum.";
"guide.amnesia.trigger.title" = "Der Auslöser";
"guide.amnesia.trigger.body" = "Wenn du das Karussell in deiner App öffnest und schließt, wird automatisch ein Befehl ausgelöst, der das sichtbare Karussell auf echtem Instagram wechselt.\n\n⚡ RICHTIGE REIHENFOLGE:\n1. Zuschauer öffnet Instagram und sieht 4 Bilder + Datum.\n2. Zuschauer schließt Instagram.\n3. Du öffnest und schließt das Karussell in deiner App → Auslöser aktiviert.\n4. Zuschauer öffnet Instagram erneut → 5 Bilder, gleiches Datum.\n\n❌ Wenn du den Auslöser BEVOR der Zuschauer das Karussell gesehen hat aktivierst, sieht er direkt 5 Bilder und der Effekt funktioniert nicht.";
"guide.amnesia.hidden.title" = "Verstecktes Bild";
"guide.amnesia.hidden.body" = "Das 5. Bild (mit orangem Rand in der App markiert) ist dasjenige, das anfangs auf Instagram archiviert ist. Der Zuschauer sieht es bei der ersten Betrachtung nicht — es erscheint nur bei der abschließenden Verifizierung.";
"guide.amnesia.options.title" = "Zwei Wege, den Auslöser zu aktivieren";
"guide.amnesia.optionA.title" = "Handgesten (theatralischer)";
"guide.amnesia.optionA.body" = "Der Zuschauer schließt Instagram. Du sagst „Ich schließe auch\" und schließt das Karussell laut in deiner App — wie eine symmetrische Geste des Rituals. Mit geschlossenen Augen des Zuschauers machst du Handgesten während du sprichst. Der Swap passiert im Hintergrund, ohne dass jemand es sieht.";
"guide.amnesia.optionB.title" = "Unauffälliges Scrollen (unsichtbarer)";
"guide.amnesia.optionB.body" = "Während der Zuschauer deiner Rede über Gedächtnis zuhört, scrollst du beiläufig in deiner App und schließt das Karussell, ohne etwas zu sagen. Der Zuschauer verbindet diese Geste nicht mit dem Effekt. Funktioniert sehr gut in Gruppen, wo niemand auf deinen Bildschirm schaut.";
"guide.amnesia.date.title" = "Datumsverifizierung — der finale Schlag";
"guide.amnesia.date.body" = "Bitte den Zuschauer zu Beginn, das Upload-Datum des Posts zu bemerken. Am Ende, wenn er 5 Bilder sieht, fragst du:\n\n„Ist es dasselbe Datum wie zuvor?\"\n\nEs ist es immer — weil beide Karussells gleichzeitig hochgeladen wurden. Instagram kann keine Daten ändern. Dieses Detail macht die Verifizierung zum unwiderlegbaren Beweis.";
"guide.amnesia.script.title" = "Vorführungs-Skript";
"guide.amnesia.script.opening.phase" = "ERÖFFNUNG";
"guide.amnesia.script.opening.text" = "„Nimm dein Handy. Öffne mein Instagram und finde diesen Post. Öffne ihn... nimm dir Zeit. Schau dir jedes Bild an, eines nach dem anderen. Beachte auch das Upload-Datum unter dem Post. Merke es dir — es ist wichtig. Hast du alle? Und das Datum? Gut.\"";
"guide.amnesia.script.close.phase" = "INSTAGRAM SCHLIESSEN";
"guide.amnesia.script.close.text" = "„Schließe jetzt Instagram vollständig aus dem App-Wechsler. Diese Bilder werden nur für einen Moment in deinem Kopf existieren. Ich möchte nicht, dass irgendetwas Äußeres dich beeinflusst. Niemand sollte deinen Bildschirm sehen.\"";
"guide.amnesia.script.optionA.phase" = "OPTION A — HANDGESTEN";
"guide.amnesia.script.optionA.text" = "„Ich schließe auch.\" [Magier schließt Karussell in App → Swap aktiviert]\n\n„Jetzt sind wir beide getrennt. Nur die Bilder bleiben... hier.\" [Zeigt auf Kopf]\n\n[Augen geschlossen] Hand ausgestreckt: „Mit jeder Bewegung... wird ein Bild unschärfer... als wäre es nie ganz da gewesen.\" [Drei langsame Gesten]\n\n„Fertig. Du kannst die Augen öffnen.\"";
"guide.amnesia.script.optionB.phase" = "OPTION B — UNAUFFÄLLIGES SCROLLEN";
"guide.amnesia.script.optionB.text" = "[Magier scrollt beiläufig in der App und schließt Karussell während er spricht]\n\n„Gedächtnis ist kein Foto. Es ist eine Rekonstruktion. Jedes Mal wenn du dich erinnerst, schreibt dein Geist es leicht um. In diesem Moment... ist Intervention möglich.\"\n\n„Wie viele Bilder erinnerst du dich genau?\" [Zuschauer: vier]";
"guide.amnesia.script.climax.phase" = "HÖHEPUNKT";
"guide.amnesia.script.climax.text" = "„Öffne Instagram erneut. Suche denselben Post.\"\n\n[Zuschauer sieht 5 Bilder]\n\n„Wie viele siehst du?\" — Fünf.\n\n„Schau auf das Datum. Ist es dasselbe wie zuvor?\" — Ja.\n\n„Instagram lügt nicht. Es kann keine Daten ändern. So wurde es hochgeladen.\"\n\n[Pause]\n\n„Was passiert ist, ist nicht, dass du ein Bild vergessen hast. Dein Geist wurde geführt, es nicht zu sehen. Und jetzt weißt du, dass das möglich ist.\"";
