"limits.help.title" = "제한 및 안전";

"limits.help.calm.title" = "안심하세요 — 모든 것이 통제되고 있습니다";
"limits.help.calm.body" = "Instagram은 가끔 본인 확인을 요청하는 짧은 알림을 표시합니다. 이는 플랫폼에 연결된 모든 앱에서 발생하는 매우 일반적인 현상이며 계정 차단과는 전혀 관련이 없습니다. Vault는 실제 앱들이 사용하는 것과 동일한 봇 방지 조치를 탑재하고 있으며, 각 조치는 철저히 테스트되었습니다.";
"limits.help.calm.infobox" = "개발 중에 제가 직접 이런 종류의 알림을 100회 이상 발생시켰지만, 제 계정은 한 번도 차단된 적이 없습니다. 같은 방식을 사용하는 다른 앱들도 문제없이 작동합니다 — 실제 위험이 있었다면 Vault는 출시되지 않았을 것입니다.";

"limits.help.warning.title" = "\"비정상적 활동\" 알림이 나타나면";
"limits.help.warning.intro" = "걱정하지 마세요 — 이것은 계정 차단이 아닙니다. Instagram이 본인임을 확인하는 것뿐입니다. 다음 단계를 따르세요:";
"limits.help.warning.step1" = "공식 Instagram 앱을 열고 알림에서 \"Dismiss\"를 탭하세요.";
"limits.help.warning.step2" = "인증을 요청하면 이메일이나 SMS 코드로 완료하세요.";
"limits.help.warning.step3" = "Vault에서 설정을 통해 로그아웃하고, 약 1분 기다린 후 다시 로그인하세요.";
"limits.help.warning.step4" = "이제 계속 사용할 수 있습니다 — 계정은 안전합니다.";
"limits.help.warning.reassure" = "계정은 정상적으로 작동합니다. 이는 Vault를 몇 분간 일시 중지시킬 뿐 그 이상은 없습니다.";

"limits.help.show.title" = "공연 중";
"limits.help.show.body" = "관객이 화면을 보고 있을 때 알림이 나타나면, Vault는 모든 기술적 세부 사항을 숨기고 일반적인 \"인터넷 연결 없음\" 화면을 표시합니다.";
"limits.help.show.infobox" = "완벽한 핑계: \"아, Instagram이 잠깐 먹통이네요, 별일 아닙니다.\" 관객은 기술적인 것을 전혀 보지 않습니다.";

"limits.help.best.title" = "권장 사항";
"limits.help.best.item1" = "같은 세션에서 같은 효과를 연속으로 여러 번 반복하지 마세요 — 알고리즘이 자동화로 표시할 수 있습니다.";
"limits.help.best.item2" = "세트(Sync & Archive)는 전날 밤 또는 공연 최소 1시간 전에 준비하세요. 연습 직후는 피하세요.";
"limits.help.best.item3" = "자주 공연한다면 메인 계정과 분리된 전용 Instagram 계정을 사용하세요.";
"limits.help.best.item4" = "Vault가 모든 대기 시간을 자동으로 관리합니다 — 당신은 아무것도 신경 쓸 필요가 없습니다.";

