// ── Limits & Safety help (simplified) ──
"limits.help.title" = "सीमाएँ और सुरक्षा";

"limits.help.calm.title" = "आराम करें — सब कुछ नियंत्रण में है";
"limits.help.calm.body" = "Instagram कभी-कभी एक संक्षिप्त सूचना दिखाता है जिसमें पुष्टि करनी होती है कि यह आप ही हैं। यह प्लेटफ़ॉर्म से जुड़े किसी भी ऐप के लिए पूरी तरह सामान्य है और बैन से इसका कोई संबंध नहीं है। Vault को उन्हीं एंटी-बॉट सुरक्षा उपायों के साथ डिज़ाइन किया गया है जो असली ऐप उपयोग करते हैं, और प्रत्येक का गहन परीक्षण किया गया है।";
"limits.help.calm.infobox" = "मैंने व्यक्तिगत रूप से विकास के दौरान इस तरह की चेतावनी 100 से अधिक बार ट्रिगर की है और मेरे अकाउंट को कभी भी बैन नहीं किया गया। उसी दृष्टिकोण वाले अन्य ऐप बिना किसी समस्या के काम करते हैं — यदि कोई वास्तविक जोखिम होता, तो Vault प्रकाशित नहीं होता।";

"limits.help.warning.title" = "यदि \"असामान्य गतिविधि\" की चेतावनी दिखे";
"limits.help.warning.intro" = "चिंता न करें — यह बैन नहीं है। यह सिर्फ़ Instagram की पुष्टि है कि यह वाकई आप हैं। इन चरणों का पालन करें:";
"limits.help.warning.step1" = "आधिकारिक Instagram ऐप खोलें और चेतावनी पर \"Dismiss\" टैप करें।";
"limits.help.warning.step2" = "यदि सत्यापन मांगे, तो ईमेल या SMS कोड से पूरा करें।";
"limits.help.warning.step3" = "Vault में सेटिंग्स से लॉग आउट करें, लगभग एक मिनट रुकें, और फिर से लॉग इन करें।";
"limits.help.warning.step4" = "जारी रखने के लिए तैयार — आपका अकाउंट सुरक्षित है।";
"limits.help.warning.reassure" = "आपका अकाउंट बिल्कुल ठीक से काम करता रहता है। यह केवल कुछ मिनटों के लिए Vault को रोकता है, और कुछ नहीं।";

"limits.help.show.title" = "प्रदर्शन के दौरान";
"limits.help.show.body" = "यदि दर्शक स्क्रीन देख रहा हो और कोई चेतावनी आए, तो Vault सभी तकनीकी विवरण छिपाकर एक सामान्य \"कोई इंटरनेट कनेक्शन नहीं\" स्क्रीन दिखाता है।";
"limits.help.show.infobox" = "सही बहाना: \"अरे, Instagram एक पल के लिए गड़बड़ा गया, कोई बड़ी बात नहीं।\" कोई भी दर्शक तकनीकी कुछ नहीं देखेगा।";

"limits.help.best.title" = "सर्वोत्तम प्रथाएँ";
"limits.help.best.item1" = "एक ही सत्र में एक ही प्रभाव को कई बार लगातार न दोहराएँ — एल्गोरिथम इसे स्वचालित मान सकता है।";
"limits.help.best.item2" = "अपने सेट (Sync & Archive) को शो से एक रात पहले या कम से कम एक घंटे पहले तैयार करें, अभ्यास के तुरंत बाद नहीं।";
"limits.help.best.item3" = "यदि आप अक्सर प्रदर्शन करते हैं, तो मुख्य से अलग एक समर्पित Instagram अकाउंट का उपयोग करें।";
"limits.help.best.item4" = "Vault सभी प्रतीक्षा समयों को स्वचालित रूप से प्रबंधित करता है — आपको कुछ भी सोचने की आवश्यकता नहीं।";

