"guide.lockscreen.help.what.body" = "Performance खोलने पर ऐप प्रोफाइल दिखाने से पहले एक नकली iOS-शैली का पासकोड स्क्रीन दिखाता है। किसी भी दर्शक को लगेगा कि आप बस फोन अनलॉक कर रहे हैं।";
"guide.lockscreen.help.how.title" = "अपना गुप्त नंबर कैसे दर्ज करें";
"guide.lockscreen.help.how.body" = "1. नंबर पैड पर अपने गुप्त नंबर के अंक टैप करें — वे चुपचाप दर्ज होते हैं।\n\n2. उन अंकों को लॉक करने के लिए नंबर पैड के बाहर टैप करें।\n\n3. बचे हुए बिंदुओं को किसी भी अंक से भरें — उन्हें अनदेखा किया जाता है।\n\n4. सभी 4 बिंदु भर जाने पर लॉकस्क्रीन बंद हो जाती है और Performance खुलता है।";
"guide.lockscreen.help.wallpaper.title" = "वॉलपेपर";
"guide.lockscreen.help.wallpaper.body" = "नकली लॉकस्क्रीन को असली जैसा दिखाने के लिए अपनी असली लॉक स्क्रीन का वही वॉलपेपर अपलोड करें। वॉलपेपर के बिना लॉकस्क्रीन इनपुट सक्षम नहीं किया जा सकता।";
"guide.lockscreen.help.why.title" = "इसका उपयोग क्यों करें?";
"guide.lockscreen.help.why.body" = "गुप्त नंबर दर्ज करने को सामान्य फोन अनलॉक के रूप में छिपाता है। नकली होम स्क्रीन के साथ मिलाने पर पूरा क्रम इस तरह दिखता है: फोन अनलॉक → होम स्क्रीन → Instagram खोलना।";
"guide.lockscreen.help.tricks.title" = "वही गुप्त नंबर — कई ट्रिक्स";
"guide.lockscreen.help.tricks.body" = "यहाँ दर्ज नंबर वही गुप्त नंबर है जो Grid Input और अन्य सभी जादू की ट्रिक्स में उपयोग किया जाता है:\n\n• किसी न्यूमेरिक सेट से फोटो अनआर्काइव करें\n• ताश का पत्ता दिखाएं\n• कस्टम इमेज दिखाएं\n• काउंटर ग्लिच प्रभाव चालू करें\n• Explore में रील फोर्स करें";
"guide.lockscreen.help.cards.title" = "ताश के पत्तों के कोड";
"guide.lockscreen.help.cards.body" = "ताश का पत्ता प्रकट करने के लिए, उसका कोड गुप्त संख्या के रूप में दर्ज करें:\n\nसूट:  1 = ♠   2 = ♥   3 = ♣   4 = ♦\n\nA–9 के पत्ते  →  [मान][सूट]\n  A♠ = 11    7♥ = 72    9♦ = 94\n\n10, J, Q, K के पत्ते  →  [दहाई][इकाई][सूट]\n  10♠ = 101    J♥ = 112\n  Q♣  = 123    K♦  = 134\n\nउदाहरण: Q♥ प्रकट करने के लिए 122 दर्ज करें।";
