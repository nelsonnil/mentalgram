"postpred.help.input.grid.label" = "ग्रिड इनपुट";
"postpred.help.input.grid.step1" = "Post Prediction सेटिंग्स में **अंक ग्रिड** सक्षम करें।";
"postpred.help.input.grid.step2" = "परफॉर्मेंस में, फोटो ग्रिड पर बाएँ या दाएँ स्वाइप करें। पोस्ट 1-9 अंक 1-9 से मेल खाती हैं। पोस्ट 10, 11 और 12 अंक 0 से मेल खाती हैं।";
"postpred.help.input.grid.step3" = "पोस्ट आइकन टैप करके पुष्टि करें और प्रकटीकरण शुरू करें।";
"postpred.help.input.ocr.label" = "OCR - कैमरा पहचान";
"postpred.help.input.ocr.step1" = "Post Prediction सेटिंग्स में **OCR** सक्षम करें।";
"postpred.help.input.ocr.step2" = "कैमरा किसी हस्तलिखित या मुद्रित शब्द की ओर करें। ऐप स्वचालित रूप से पढ़ती है।";
"postpred.help.input.url.label" = "URL स्कीम";
"postpred.help.input.url.step1" = "Post Prediction सेटिंग्स में **URL Scheme** सक्षम करें।";
"postpred.help.input.url.step2" = "कस्टम URL से दूरस्थ रूप से प्रकटीकरण शुरू करें।";
"postpred.help.before.1" = "Sets सेक्शन में एक **सेट** बनाएं। अक्षर प्रकार चुनें और इमेज टेम्पलेट चुनें या अपनी फोटो अपलोड करें।";
"postpred.help.before.2" = "इमेज अपलोड करें और **स्वचालित रूप से संग्रहित** होने की प्रतीक्षा करें। इसमें कई घंटे लग सकते हैं।";
"postpred.help.before.3" = "अपलोड के दौरान **ऐप का उपयोग न करें**, नेटवर्क न बदलें, प्रक्रिया बाधित न करें।";
"postpred.help.before.4" = "अपलोड किए गए सेट को Post Prediction सेटिंग्स में **सक्रिय** के रूप में सेट करें।";
"postpred.help.before.5" = "कम से कम एक **इनपुट विधि** सक्षम करें: ग्रिड, OCR या URL स्कीम।";
"postpred.help.during.step.invite" = "स्वतंत्र पसंद";
"postpred.help.during.invite.action" = "दर्शक से स्वतंत्र रूप से एक शब्द, संख्या या अक्षर सोचने को कहें।";
"postpred.help.during.invite.dialogue" = "कोई भी शब्द सोचें या कोई भी संख्या। कुछ व्यक्तिगत। अभी मत बोलिए।";
"postpred.help.during.step.input" = "पसंद कैप्चर करना";
"postpred.help.during.input.action" = "जब दर्शक अपनी पसंद जोर से बोले, ग्रिड, OCR या URL से चुपचाप कैप्चर करें।";
"postpred.help.during.input.dialogue" = "अब जोर से बोलिए, सभी को सुनाई दे इतना जोर से।";
"postpred.help.during.step.reveal" = "प्रकटीकरण";
"postpred.help.during.reveal.action" = "ऐप संबंधित फोटो का संग्रह हटा देती है। ऐप में परिणाम 2-3 सेकंड में आता है। असली Instagram पर, प्रत्येक फोटो अलग-अलग संग्रह हटाई जाती है।";
"postpred.help.during.timing.action" = "जब ऐप कंपन करे, तो असली Instagram पर प्रकटीकरण लाइव है।";
"postpred.help.during.timing.dialogue" = "Instagram खोलें। मेरी प्रोफाइल पर जाएं। नीचे स्क्रॉल करें, यह हमेशा से वहाँ था।";
"postpred.help.tip.timing" = "**प्रकटीकरण गति।** एक अक्षर या अंक: ~2-3 सेकंड। पाँच अक्षर (जैसे MAGIC): ~12-15 सेकंड।";
"postpred.help.tip.vibration" = "**कंपन = तैयार।** हैप्टिक फीडबैक संकेत है कि फोटो असली Instagram पर लाइव है।";
"postpred.help.tip.position" = "**मूल स्थिति।** फोटो ग्रिड में ठीक उसी स्थान पर, मूल तारीख के साथ दिखती है।";
"postpred.help.tip.upload" = "**अपलोड के दौरान।** ऐप का उपयोग न करें, Wi-Fi नेटवर्क न बदलें, स्क्रीन लॉक न करें।";
"postpred.help.tip.banks" = "**बैंकों की संख्या।** प्रत्येक बैंक = एक अक्षर या अंक स्थान।";
