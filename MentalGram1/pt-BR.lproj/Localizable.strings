"limits.help.title" = "Limites e segurança";

"limits.help.calm.title" = "Relaxe — está tudo sob controle";
"limits.help.calm.body" = "O Instagram às vezes mostra um aviso breve pedindo para confirmar que é você. Isso é completamente normal para qualquer app conectado à plataforma e não tem nada a ver com um banimento. O Vault foi projetado com as mesmas proteções anti-bot que apps reais usam, e cada uma foi testada exaustivamente.";
"limits.help.calm.infobox" = "Pessoalmente, provoquei esse tipo de aviso mais de 100 vezes durante o desenvolvimento e minha conta nunca foi banida. Outros apps com a mesma abordagem funcionam sem problemas — se houvesse um risco real, o Vault não estaria publicado.";

"limits.help.warning.title" = "Se aparecer um aviso de \"Atividade incomum\"";
"limits.help.warning.intro" = "Não se preocupe — não é um banimento. É só o Instagram confirmando que é realmente você. Siga estes passos:";
"limits.help.warning.step1" = "Abra o app oficial do Instagram e toque em \"Dismiss\" no aviso.";
"limits.help.warning.step2" = "Se pedir verificação, conclua com o código de e-mail ou SMS.";
"limits.help.warning.step3" = "No Vault, saia da conta em Configurações, espere cerca de um minuto e entre novamente.";
"limits.help.warning.step4" = "Pronto para continuar — sua conta está segura.";
"limits.help.warning.reassure" = "Sua conta continua funcionando perfeitamente. Isso só pausa o Vault por alguns minutos, nada mais.";

"limits.help.show.title" = "Durante uma apresentação";
"limits.help.show.body" = "Se um aviso aparecer enquanto o espectador estiver olhando para a tela, o Vault esconde todos os detalhes técnicos e mostra uma tela genérica \"Sem conexão com a internet\".";
"limits.help.show.infobox" = "Desculpa perfeita: \"Ih, o Instagram deu uma travada, nada de mais.\" Nenhum espectador verá nada técnico.";

"limits.help.best.title" = "Boas práticas";
"limits.help.best.item1" = "Não repita o mesmo efeito várias vezes seguidas na mesma sessão — o algoritmo pode marcar como automatizado.";
"limits.help.best.item2" = "Prepare seus sets (Sync & Archive) na noite anterior ou pelo menos uma hora antes do show, não logo após ensaiar.";
"limits.help.best.item3" = "Se você se apresenta com frequência, use uma conta do Instagram dedicada, separada da principal.";
"limits.help.best.item4" = "O Vault gerencia automaticamente todos os tempos de espera — você não precisa pensar em nada.";

// ── Guide: Camouflage section ──
"guide.section.camouflage" = "CAMUFLAGEM";
"guide.fakehome.title" = "Tela Inicial Falsa";
"guide.fakehome.subtitle" = "Mostra uma captura da tela inicial ao abrir o Performance";
"guide.fakehome.help.what.title" = "O que é a tela inicial falsa?";
"guide.fakehome.help.what.body" = "Ao abrir o Performance, em vez de ir diretamente para o seu perfil, o app mostra primeiro uma captura de tela da sua tela inicial real do iPhone. Para um observador, parecerá que você está abrindo o Instagram normalmente.";
"guide.fakehome.help.how.title" = "Como usar";
"guide.fakehome.help.how.body" = "1. Tire uma captura real da sua tela inicial com o ícone do Instagram visível.\n\n2. Faça o upload em Configurações › Outros › Tela Inicial Falsa.\n\n3. Ative o interruptor.\n\n4. Na próxima vez que abrir o Performance, essa captura aparecerá em tela cheia — toque em qualquer lugar (de preferência no ícone do Instagram) para revelar seu perfil.";
"guide.fakehome.help.why.title" = "Por que usar?";
"guide.fakehome.help.why.body" = "Cria a ilusão de que você está simplesmente abrindo o app real do Instagram. Quem olhar sua tela verá apenas a tela inicial normal antes do seu perfil aparecer.";
"guide.lockscreen.title" = "Entrada pela Tela de Bloqueio";
"guide.lockscreen.subtitle" = "Tela de bloqueio iOS falsa para entrada secreta de dígitos";
"guide.lockscreen.help.what.title" = "O que é a entrada pela tela de bloqueio?";
"guide.lockscreen.help.what.body" = "Ao abrir o Performance, o app mostra uma tela de código falsa no estilo iOS. Para qualquer observador, parecerá que você está simplesmente desbloqueando o telefone.";
"guide.lockscreen.help.how.title" = "Como inserir seu número secreto";
"guide.lockscreen.help.how.body" = "1. Toque os dígitos do seu número secreto no teclado numérico — eles são registrados silenciosamente.\n\n2. Toque fora do teclado para bloquear esses dígitos.\n\n3. Preencha os pontos restantes com quaisquer dígitos — eles são ignorados.\n\n4. Quando os 4 pontos estiverem preenchidos, a tela de bloqueio fecha e o Performance abre.";
"guide.lockscreen.help.wallpaper.title" = "Papel de Parede";
"guide.lockscreen.help.wallpaper.body" = "Faça upload do mesmo papel de parede que você usa na tela de bloqueio real para que a falsa seja idêntica. Sem papel de parede, a entrada pela tela de bloqueio não pode ser ativada.";
"guide.lockscreen.help.why.title" = "Por que usar?";
"guide.lockscreen.help.why.body" = "Disfarça a entrada de um número secreto como um desbloqueio normal do telefone. Combinado com a tela inicial falsa, a sequência completa parece: desbloquear → tela inicial → abrir Instagram.";
"guide.lockscreen.help.tricks.title" = "O mesmo número secreto — muitos truques";
"guide.lockscreen.help.tricks.body" = "O número inserido aqui é o mesmo usado pela entrada em grade e todos os outros truques:\n\n• Desarquivar uma foto de um set numérico\n• Revelar uma carta\n• Mostrar uma imagem personalizada\n• Ativar o efeito contador\n• Forçar um reel no Explorar";
"guide.lockscreen.help.cards.title" = "Códigos das cartas";
"guide.lockscreen.help.cards.body" = "Para revelar uma carta, insira seu código como número secreto:\n\nNaipes:  1 = ♠   2 = ♥   3 = ♣   4 = ♦\n\nCartas A–9  →  [valor][naipe]\n  A♠ = 11    7♥ = 72    9♦ = 94\n\nCartas 10, J, Q, K  →  [dezena][unidade][naipe]\n  10♠ = 101    J♥ = 112\n  Q♣  = 123    K♦  = 134\n\nExemplo: para revelar Q♥ insira 122.";
