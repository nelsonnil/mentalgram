"postpred.help.nav.subtitle" = "Guia de performance";
"postpred.help.hero.title" = "A previsao de imagem";
"postpred.help.hero.body" = "Uma imagem selecionada aparece no seu perfil do Instagram na sua posicao original exata, com sua data original, escolhida em tempo real pelo espectador.";
"postpred.help.section.howitworks" = "Como funciona";
"postpred.help.section.inputs" = "Metodos de entrada";
