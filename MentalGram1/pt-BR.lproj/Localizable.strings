"SELECT FORCED POST" = "SELECIONAR POST FORÇADO";
"\"Open any profile — a friend, a celebrity, anyone. Look at their posts.\"" = "\"Abra qualquer perfil — um amigo, uma celebridade, qualquer um. Olhe os posts deles.\"";
