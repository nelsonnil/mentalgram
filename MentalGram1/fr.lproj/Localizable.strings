// Post Prediction Help
"postpred.help.nav.title" = "Post Prediction";
"postpred.help.nav.subtitle" = "Guide de performance";
"postpred.help.hero.title" = "La prediction d'image";
"postpred.help.hero.body" = "Une image selectionnee apparait sur votre profil Instagram a sa position originale exacte, avec sa date d'origine, choisie en temps reel par le spectateur.";
"postpred.help.section.howitworks" = "Comment ca marche";
"postpred.help.section.inputs" = "Methodes de saisie";
"postpred.help.section.before" = "Avant le show";
"postpred.help.section.during" = "Pendant le show";
"postpred.help.section.tips" = "Conseils";
"postpred.help.howitworks.body1" = "Vous preparez un **Set** de photos, une par lettre ou chiffre. Les photos sont telechargees a l'avance et archivees automatiquement, donc invisibles sur Instagram jusqu'a ce que vous choisissiez de les reveler.";
"postpred.help.howitworks.body2" = "Lorsque vous declenchez la revelation, l'app desarchive la photo correspondante. Elle reapparait a sa **position originale dans la grille**, avec sa **date d'origine**, comme si elle avait toujours ete la.";
"postpred.help.howitworks.info" = "Le spectateur voit une vraie publication sur un vrai profil Instagram. Aucune app n'est visible, juste Instagram.";
"postpred.help.metric.sets" = "Sets";
"postpred.help.metric.sets.desc" = "Collections de photos (lettres A-Z ou chiffres 0-9) telechargees et archivees a l'avance, pretes a etre revelees.";
"postpred.help.metric.banks" = "Banques";
"postpred.help.metric.banks.desc" = "Chaque banque = une position dans le mot ou le nombre. Banque 1 -> premiere lettre, Banque 2 -> deuxieme lettre, etc. Le nombre de banques definit la longueur maximale de ce que vous pouvez reveler.";
"postpred.help.inputs.body1" = "Le spectateur pense librement a un mot ou un nombre. Vous capturez son choix silencieusement grace a l'une des trois methodes:";
"postpred.help.input.grid.label" = "SAISIE PAR GRILLE";
"postpred.help.input.grid.step1" = "Activez **Grille de chiffres** dans les parametres Post Prediction.";
"postpred.help.input.grid.step2" = "Dans Performance, faites glisser a gauche ou a droite sur la grille de photos. Les posts 1-9 correspondent aux chiffres 1-9. Les posts 10, 11 et 12 correspondent au chiffre 0. Un indicateur affiche le nombre accumule.";
"postpred.help.input.grid.step3" = "Appuyez sur l'icone Posts pour confirmer et declencher la revelation.";
"postpred.help.input.ocr.label" = "OCR - RECONNAISSANCE CAMERA";
"postpred.help.input.ocr.step1" = "Activez **OCR** dans les parametres Post Prediction.";
"postpred.help.input.ocr.step2" = "Pointez la camera vers un mot ecrit a la main ou imprime. L'app le lit automatiquement et declenche la revelation correspondante.";
"postpred.help.input.url.label" = "SCHEMA URL";
"postpred.help.input.url.step1" = "Activez **URL Scheme** dans les parametres Post Prediction.";
"postpred.help.input.url.step2" = "Declenchez la revelation a distance via une URL personnalisee, utile avec des tags NFC, des QR codes ou des raccourcis d'automatisation.";
"postpred.help.before.1" = "Creez un **Set** dans la section Sets. Choisissez le type de lettre (Numerique ou Mot) et selectionnez un modele d'image ou telechargez vos propres photos.";
"postpred.help.before.2" = "Telechargez les images et attendez qu'elles soient **archivees automatiquement**. Cela peut prendre plusieurs heures, laissez l'app active toute la nuit si necessaire.";
"postpred.help.before.3" = "Pendant le telechargement, **n'utilisez pas l'app**, ne changez pas de reseau et n'interrompez pas le processus. L'ecran reste allume automatiquement. Une notification vous invite a revenir entre chaque telechargement.";
"postpred.help.before.4" = "Definissez le Set telecharge comme **actif** dans les parametres Post Prediction.";
"postpred.help.before.5" = "Activez au moins une **methode de saisie**: Grille, OCR ou URL Scheme.";
"postpred.help.during.step.invite" = "LE CHOIX LIBRE";
"postpred.help.during.invite.action" = "Demandez au spectateur de penser librement a un mot, un nombre ou une lettre. Ne suggerez rien.";
"postpred.help.during.invite.dialogue" = "Pensez a n'importe quel mot, ou n'importe quel nombre. Quelque chose de personnel, quelque chose que vous seul connaissez. Ne le dites pas encore.";
"postpred.help.during.step.input" = "CAPTURE DU CHOIX";
"postpred.help.during.input.action" = "Capturez l'entree silencieusement avec la Grille, l'OCR ou l'URL Scheme, pendant que le spectateur enonce son choix a voix haute.";
"postpred.help.during.input.dialogue" = "Dites-le a voix haute maintenant, assez fort pour que tout le monde entende.";
"postpred.help.during.step.reveal" = "LA REVELATION";
"postpred.help.during.reveal.action" = "L'app desarchive la photo correspondante. Dans l'app, le resultat apparait en 2-3 secondes. Sur Instagram reel, chaque photo est desarchivee individuellement avec une courte pause, le temps total depend de la longueur du mot.";
"postpred.help.during.timing.action" = "Quand l'app vibre, la revelation est en direct sur Instagram reel. Dirigez le spectateur vers Instagram.";
"postpred.help.during.timing.dialogue" = "Ouvrez Instagram. Allez sur mon profil. Faites defiler vers le bas, c'etait la depuis le debut.";
"postpred.help.tip.timing" = "**Vitesse de revelation.** Une lettre ou un chiffre: ~2-3 secondes. Cinq lettres (ex. MAGIC): ~12-15 secondes. Chaque lettre supplementaire ajoute ~2-3 secondes.";
"postpred.help.tip.vibration" = "**Vibration = pret.** Le retour haptique signale que la photo est en direct sur Instagram reel. Une fois la vibration sentie, guidez le spectateur.";
"postpred.help.tip.position" = "**Position originale.** La photo reapparait exactement la ou elle etait dans la grille, avec sa date d'origine. Il peut etre necessaire de faire defiler pour la trouver.";
"postpred.help.tip.upload" = "**Pendant le telechargement.** N'utilisez pas l'app, ne changez pas de reseau Wi-Fi et ne laissez pas l'ecran se verrouiller. Une notification vous invite a revenir entre chaque telechargement.";
"postpred.help.tip.banks" = "**Nombre de Banques.** Chaque banque = une position de lettre ou de chiffre. Planifiez vos sets en fonction du mot ou nombre le plus long que vous souhaitez reveler.";

