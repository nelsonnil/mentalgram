"perf.help.realdata.title" = "Données Instagram réelles";
"perf.help.overview.body1" = "Performance est un émulateur Instagram intégré. Il ressemble et fonctionne comme la vraie app Instagram, mais il s'exécute dans Vault et est directement connecté à votre compte Instagram via l'API officielle.";
"perf.help.overview.infobox" = "Tout ce que le spectateur voit est du vrai contenu Instagram de votre compte réel — publications, abonnés, reels — récupéré en direct depuis l'API. Ce n'est pas une simulation ; c'est votre vrai profil.";
"perf.help.overview.body2" = "Le spectateur peut tenir votre téléphone, ouvrir n'importe quel profil, défiler librement et voir de vraies données Instagram à tout moment. Vault fonctionne invisiblement en arrière-plan.";
"perf.help.plus.body" = "Pour accéder aux Réglages depuis Performance, appuyez sur le bouton + situé dans le coin supérieur gauche de la barre d'en-tête — la même barre qui affiche votre nom d'utilisateur au centre. C'est le seul moyen de revenir aux Réglages en mode Performance.";
"perf.help.plus.infobox" = "Configurez tous vos tours (Force Post, Force Reel, Date Force, Counter Glitch, etc.) dans Réglages avant le spectacle. Une fois en Performance, utilisez le bouton + pour revenir et ajuster si nécessaire.";
"perf.help.plus.mock.label" = "Barre d'en-tête";
"perf.help.plus.mock.sublabel" = "Appuyez sur + (en haut à gauche) pour ouvrir les Réglages";
"perf.help.profile.followers.title" = "Compteur d'abonnés — cliquable";
"perf.help.profile.followers.desc" = "Appuyez sur le compteur d'abonnés pour ouvrir la liste complète. En mode Date Force, appuyez sur le cercle de l'avatar pour sélectionner des spectateurs — un numéro bleu (1, 2, 3…) indique l'ordre de sélection. Première moitié = groupe date, deuxième moitié = groupe heure. Appuyez en dehors du cercle pour ouvrir le profil de cette personne.";
"perf.help.profile.tabs.title" = "Onglets Publications / Reels / Identifiés";
"perf.help.profile.tabs.desc" = "Passez entre les trois onglets pour parcourir les publications, reels et photos identifiées du profil. Appuyez sur n'importe quelle miniature pour la voir en plein écran.";
"perf.help.profile.refresh.title" = "Tirer pour actualiser";
"perf.help.profile.refresh.desc" = "Tirez vers le bas sur le profil pour le recharger depuis Instagram et afficher les modifications récentes (nouveaux abonnés, bio mise à jour, photos récemment téléchargées).";
"perf.help.bottombar.body" = "La barre de navigation inférieure imite l'interface d'Instagram. La plupart des boutons sont décoratifs — seule la loupe (Rechercher) est fonctionnelle et ouvre Explorer.";
"perf.help.bottombar.infobox" = "Le bouton Rechercher/loupe est le principal moyen de naviguer vers Explorer. Appuyez pour parcourir des reels aléatoires et rechercher n'importe quel profil Instagram par nom d'utilisateur.";
"perf.help.mock.home" = "Accueil";
"perf.help.mock.search" = "Rechercher";
"perf.help.mock.send" = "Envoyer";
"perf.help.mock.profile" = "Profil";
"perf.help.mock.active" = "✓ Actif";
"perf.help.mock.posts" = "Publications";
"perf.help.mock.reels" = "Reels";
"perf.help.mock.tagged" = "Identifiés";
"perf.help.explore.body" = "La vue Explorer s'ouvre lorsque vous appuyez sur la loupe dans la barre inférieure. Elle affiche un vrai feed Instagram Explorer avec des reels aléatoires et une barre de recherche en haut pour trouver n'importe quel profil.";
"perf.help.explore.reels.title" = "Feed de reels aléatoires";
"perf.help.explore.reels.desc" = "Explorer affiche de vrais reels Instagram. Le spectateur peut défiler librement. En mode Force Reel, le reel cible apparaît à la position que vous avez composée secrètement.";
"perf.help.explore.search.title" = "Rechercher n'importe quel profil réel";
"perf.help.explore.search.desc" = "Tapez n'importe quel nom d'utilisateur dans la barre de recherche pour charger leur vrai profil Instagram — photos, abonnés, abonnements — directement depuis l'API. Le spectateur peut librement choisir qui regarder.";
"perf.help.explore.infobox" = "En mode Force Reel, chercher et faire glisser entre les onglets (Publications/Reels/Identifiés) sur un profil enregistre secrètement chaque chiffre du nombre du spectateur. Lorsque vous ouvrez Explorer, le reel apparaît exactement à cette position.";
"perf.help.realdata.body" = "Parce que Performance est connecté à la vraie API Instagram, toutes les données que vous voyez sont authentiques et actuelles. Il n'y a pas de contenu préchargé.";
"perf.help.realdata.item1" = "Les photos et vidéos sont chargées en direct depuis votre vrai compte Instagram";
"perf.help.realdata.item2" = "Les compteurs d'abonnés et d'abonnements sont réels — et peuvent être secrètement manipulés pour les effets";
"perf.help.realdata.item3" = "Tout profil que vous recherchez charge ses vrais posts, reels et biographie depuis l'API";
"perf.help.realdata.item4" = "Les mises à jour de biographie et les téléchargements de photos effectués depuis les Réglages apparaissent sur le vrai profil Instagram";

