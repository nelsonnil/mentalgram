"ig.private.title" = "Ce compte est privé";
"ig.private.subtitle" = "Suivez ce compte pour voir ses photos et vidéos.";

// ── Limits & Safety help (simplified) ──
"limits.help.title" = "Limites et sécurité";

"limits.help.calm.title" = "Rassure-toi — tout est sous contrôle";
"limits.help.calm.body" = "Instagram affiche de temps en temps un bref avertissement demandant de confirmer que c'est bien toi. C'est tout à fait normal pour n'importe quelle app connectée à la plateforme et n'a rien à voir avec un bannissement. Vault est conçue avec les mêmes protections anti-bot que les vraies apps, et chacune a été testée en profondeur.";
"limits.help.calm.infobox" = "J'ai personnellement déclenché ce type d'avertissement plus de 100 fois pendant le développement et mon compte n'a jamais été banni. D'autres apps avec la même approche fonctionnent sans souci — s'il y avait un vrai risque, Vault ne serait pas publiée.";

"limits.help.warning.title" = "Si un avertissement \"Activité inhabituelle\" apparaît";
"limits.help.warning.intro" = "Pas d'inquiétude — ce n'est pas un bannissement. C'est juste Instagram qui confirme que c'est bien toi. Suis ces étapes :";
"limits.help.warning.step1" = "Ouvre l'app officielle Instagram et appuie sur \"Dismiss\" sur l'avertissement.";
"limits.help.warning.step2" = "S'il demande une vérification, complète-la avec le code email ou SMS.";
"limits.help.warning.step3" = "Dans Vault, déconnecte-toi depuis les Réglages, attends environ une minute et reconnecte-toi.";
"limits.help.warning.step4" = "Tu peux continuer — ton compte est en sécurité.";
"limits.help.warning.reassure" = "Ton compte continue de fonctionner parfaitement. Cela ne met Vault en pause que quelques minutes, rien de plus.";

"limits.help.show.title" = "Pendant un spectacle";
"limits.help.show.body" = "Si un avertissement apparaît pendant que le spectateur regarde l'écran, Vault masque tous les détails techniques et affiche un écran générique \"Pas de connexion Internet\".";
"limits.help.show.infobox" = "Excuse parfaite : \"Ah, Instagram bugue un instant, rien de grave.\" Aucun spectateur ne verra rien de technique.";

"limits.help.best.title" = "Bonnes pratiques";
"limits.help.best.item1" = "Ne répète pas le même effet plusieurs fois de suite dans la même session — l'algorithme peut le marquer comme automatisé.";
"limits.help.best.item2" = "Prépare tes sets (Sync & Archive) la veille au soir ou au moins une heure avant le spectacle, pas juste après avoir répété.";
"limits.help.best.item3" = "Si tu joues souvent, utilise un compte Instagram dédié, séparé de ton compte principal.";
"limits.help.best.item4" = "Vault gère automatiquement tous les temps d'attente — tu n'as à t'occuper de rien.";

// ── Guide: Camouflage section ──
"guide.section.camouflage" = "CAMOUFLAGE";
"guide.fakehome.title" = "Faux écran d'accueil";
"guide.fakehome.subtitle" = "Affiche une capture d'écran de l'écran d'accueil à l'ouverture de Performance";
"guide.fakehome.help.what.title" = "Qu'est-ce que le faux écran d'accueil?";
"guide.fakehome.help.what.body" = "Lorsque vous ouvrez Performance, au lieu d'aller directement à votre profil, l'application affiche d'abord une capture d'écran de votre vrai écran d'accueil iPhone. Pour un observateur, cela ressemble à une ouverture normale d'Instagram.";
"guide.fakehome.help.how.title" = "Comment l'utiliser";
"guide.fakehome.help.how.body" = "1. Prenez une vraie capture d'écran de votre écran d'accueil avec l'icône Instagram visible.\n\n2. Téléchargez-la dans Réglages › Autres › Faux écran d'accueil.\n\n3. Activez le bouton.\n\n4. La prochaine fois que vous ouvrez Performance, cette capture apparaît en plein écran — appuyez n'importe où (idéalement sur l'icône Instagram) pour révéler votre profil.";
"guide.fakehome.help.why.title" = "Pourquoi l'utiliser?";
"guide.fakehome.help.why.body" = "Cela crée l'illusion que vous ouvrez simplement la vraie application Instagram. Quiconque regarde votre écran ne voit que l'écran d'accueil normal avant que votre profil apparaisse.";
"guide.lockscreen.title" = "Saisie sur écran de verrouillage";
"guide.lockscreen.subtitle" = "Faux écran de verrouillage iOS pour la saisie secrète de chiffres";
"guide.lockscreen.help.what.title" = "Qu'est-ce que la saisie sur écran de verrouillage?";
"guide.lockscreen.help.what.body" = "Lors de l'ouverture de Performance, l'application affiche un faux écran de code d'accès style iOS. Pour tout observateur, cela ressemble à un simple déverrouillage du téléphone.";
"guide.lockscreen.help.how.title" = "Comment saisir votre numéro secret";
"guide.lockscreen.help.how.body" = "1. Tapez les chiffres de votre numéro secret sur le pavé numérique — ils s'enregistrent silencieusement.\n\n2. Tapez en dehors du pavé pour verrouiller ces chiffres.\n\n3. Remplissez les points restants avec n'importe quels chiffres — ils sont ignorés.\n\n4. Une fois les 4 points remplis, l'écran de verrouillage se ferme et Performance s'ouvre.";
"guide.lockscreen.help.wallpaper.title" = "Fond d'écran";
"guide.lockscreen.help.wallpaper.body" = "Téléchargez le même fond d'écran que votre vrai écran de verrouillage pour que le faux soit identique. Sans fond d'écran, la saisie sur écran de verrouillage ne peut pas être activée.";
"guide.lockscreen.help.why.title" = "Pourquoi l'utiliser?";
"guide.lockscreen.help.why.body" = "Cela déguise la saisie d'un numéro secret en déverrouillage normal du téléphone. Combiné avec le faux écran d'accueil, la séquence complète ressemble à: déverrouiller → écran d'accueil → ouvrir Instagram.";
"guide.lockscreen.help.tricks.title" = "Le même numéro secret — plusieurs tours";
"guide.lockscreen.help.tricks.body" = "Le numéro saisi ici est le même que celui utilisé par la saisie en grille et tous les autres tours de magie:\n\n• Désarchiver une photo d'un set numérique\n• Révéler une carte à jouer\n• Afficher une image personnalisée\n• Activer l'effet de compteur\n• Forcer un reel dans Explorer";
"guide.lockscreen.help.cards.title" = "Codes des cartes";
"guide.lockscreen.help.cards.body" = "Pour révéler une carte, saisissez son code comme numéro secret :\n\nCouleurs :  1 = ♠   2 = ♥   3 = ♣   4 = ♦\n\nCartes A–9  →  [valeur][couleur]\n  A♠ = 11    7♥ = 72    9♦ = 94\n\nCartes 10, V, D, R  →  [dizaine][unité][couleur]\n  10♠ = 101    V♥ = 112\n  D♣  = 123    R♦  = 134\n\nExemple : pour révéler D♥ saisissez 122.";
