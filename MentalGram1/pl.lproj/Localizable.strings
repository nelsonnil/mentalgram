"perf.help.explore.body" = "Widok Eksploruj otwiera się po dotknięciu lupy na dolnym pasku. Pokazuje prawdziwy feed Instagram Eksploruj z losowymi reelami i paskiem wyszukiwania u góry, aby znaleźć dowolny profil.";
"perf.help.explore.reels.title" = "Losowy feed reeli";
"perf.help.explore.reels.desc" = "Eksploruj pokazuje prawdziwe reele z Instagrama. Widz może swobodnie przewijać. W trybie Force Reel docelowy reel pojawia się na pozycji, którą potajemnie wybrałeś.";
"perf.help.explore.search.title" = "Wyszukaj dowolny prawdziwy profil";
"perf.help.explore.search.desc" = "Wpisz dowolną nazwę użytkownika w pasku wyszukiwania, aby załadować ich prawdziwy profil Instagram — zdjęcia, obserwujący, obserwowani — bezpośrednio z API. Widz może swobodnie wybrać, kogo oglądać.";
"perf.help.explore.infobox" = "W trybie Force Reel wyszukiwanie i przesuwanie między zakładkami (Posty/Reele/Oznaczone) na profilu potajemnie rejestruje każdą cyfrę liczby widza. Po otwarciu Eksploruj reel pojawia się dokładnie na tej pozycji.";
"perf.help.realdata.body" = "Ponieważ Performance jest połączony z prawdziwym API Instagrama, wszystkie widoczne dane są autentyczne i aktualne. Nie ma wstępnie załadowanych treści.";
"perf.help.realdata.item1" = "Zdjęcia i filmy są ładowane na żywo z twojego prawdziwego konta Instagram";
"perf.help.realdata.item2" = "Liczniki obserwujących i obserwowanych są prawdziwe — i można je potajemnie manipulować dla efektów";
"perf.help.realdata.item3" = "Każdy profil, który wyszukasz, ładuje swoje prawdziwe posty, reele i biografię z API";
"perf.help.realdata.item4" = "Aktualizacje biografii i przesyłanie zdjęć z Ustawień pojawiają się na prawdziwym profilu Instagram";

