"postpred.help.nav.title" = "Post Prediction";
"postpred.help.nav.subtitle" = "Przewodnik po wystepie";
"postpred.help.hero.title" = "Przepowiednia obrazu";
"postpred.help.hero.body" = "Wybrany obraz pojawia sie na Twoim profilu Instagram na swojej oryginalnej pozycji, z oryginaln. dat., wybrany przez widza w czasie rzeczywistym.";
"postpred.help.section.howitworks" = "Jak to dziala";
