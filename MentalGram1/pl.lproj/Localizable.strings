"perf.help.plus.mock.sublabel" = "Dotknij + (lewy górny róg) aby otworzyć Ustawienia";
"perf.help.profile.followers.title" = "Licznik obserwujących — do kliknięcia";
"perf.help.profile.followers.desc" = "Dotknij licznika obserwujących, aby otworzyć pełną listę. W trybie Date Force dotknij okrąg awatara, aby wybrać widzów — niebieska liczba (1, 2, 3…) pokazuje kolejność wyboru. Pierwsza połowa = grupa daty, druga połowa = grupa godziny. Dotknij poza okrągiem, aby otworzyć profil tej osoby.";
"perf.help.profile.tabs.title" = "Zakładki Posty / Reele / Oznaczone";
"perf.help.profile.tabs.desc" = "Przełączaj między trzema zakładkami, aby przeglądać posty, reele i oznaczone zdjęcia profilu. Dotknij dowolnej miniatury, aby zobaczyć ją na pełnym ekranie.";
"perf.help.profile.refresh.title" = "Pociągnij, aby odświeżyć";
"perf.help.profile.refresh.desc" = "Pociągnij profil w dół, aby przeładować go z Instagrama i pokazać ostatnie zmiany (nowi obserwujący, zaktualizowane bio, nowo przesłane zdjęcia).";
"perf.help.bottombar.body" = "Dolny pasek nawigacji naśladuje interfejs Instagrama. Większość przycisków jest dekoracyjna — tylko lupa (Szukaj) jest funkcjonalna i otwiera Eksploruj.";
"perf.help.bottombar.infobox" = "Przycisk Szukaj/lupa jest głównym sposobem nawigacji do Eksploruj. Dotknij, aby przeglądać losowe reele i wyszukiwać dowolny profil Instagrama po nazwie użytkownika.";
