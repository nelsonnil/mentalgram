"postpred.help.section.tips" = "Wskazowki";
"postpred.help.howitworks.body1" = "Przygotowujesz **Zestaw** zdj.c, po jednym na kazd. liter. lub cyfr.. Zdj.cia s. przesylane z gory i automatycznie archiwizowane, wiec s. niewidoczne na Instagramie, dopoki nie zdecydujesz si. ich ujawnic.";
"postpred.help.howitworks.body2" = "Gdy uruchomisz ujawnienie, aplikacja odarchiwizuje odpowiednie zdjecie. Pojawia sie ono na **oryginalnej pozycji w siatce** z **oryginaln. dat.**, jakby zawsze tam bylo.";
"postpred.help.howitworks.info" = "Widz widzi prawdziwy post na prawdziwym profilu Instagram. Zadna aplikacja nie jest widoczna, tylko Instagram.";
"postpred.help.metric.sets" = "Zestawy";
"postpred.help.metric.sets.desc" = "Kolekcje zdj.c przeslanych i zarchiwizowanych z gory. Gotowe do ujawnienia.";
"postpred.help.metric.banks" = "Banki";
"postpred.help.metric.banks.desc" = "Kazdy bank = jedna pozycja w slowie lub liczbie. Bank 1 -> pierwsza litera, Bank 2 -> druga litera. Liczba bankow okresla maksymaln. dlugosc ujawnienia.";
"postpred.help.inputs.body1" = "Widz swobodnie mysli o slowie lub liczbie. Przechwycisz jego wybor po cichu jedn. z trzech metod:";
"postpred.help.input.grid.label" = "WPROWADZANIE SIATK.";
"postpred.help.input.grid.step1" = "Wlacz **Siatk. cyfr** w ustawieniach Post Prediction.";
"postpred.help.input.grid.step2" = "W Wynikach przesu. w lewo lub prawo po siatce zdj.c. Posty 1-9 odpowiadaj. cyfrom 1-9. Posty 10, 11 i 12 odpowiadaj. cyfrze 0.";
"postpred.help.input.grid.step3" = "Dotknij ikony Postow, aby potwierdzic i uruchomi. ujawnienie.";
"postpred.help.input.ocr.label" = "OCR - ROZPOZNAWANIE KAMER.";
"postpred.help.input.ocr.step1" = "Wlacz **OCR** w ustawieniach Post Prediction.";
"postpred.help.input.ocr.step2" = "Skieruj kamere na odrecznne lub wydrukowane slowo. Aplikacja odczyta je automatycznie i uruchomi odpowiednie ujawnienie.";
"postpred.help.input.url.label" = "SCHEMAT URL";
"postpred.help.input.url.step1" = "Wlacz **URL Scheme** w ustawieniach Post Prediction.";
"postpred.help.input.url.step2" = "Uruchom ujawnienie zdalnie przez niestandardowy URL. Przydatne z tagami NFC, kodami QR lub skrotami automatyzacji.";
"postpred.help.before.1" = "Utworz **Zestaw** w sekcji Zestawy. Wybierz typ litery i szablon obrazu lub przesl. wlasne zdj.cia.";
"postpred.help.before.2" = "Prze. lij obrazy i poczekaj, az zostana **automatycznie zarchiwizowane**. Mo.e to zaj.c kilka godzin.";
"postpred.help.before.3" = "Podczas przesylania **nie korzystaj z aplikacji**, nie zmieniaj sieci i nie przerywaj procesu. Ekran pozostaje aktywny automatycznie.";
"postpred.help.before.4" = "Ustaw przeslany Zestaw jako **aktywny** w ustawieniach Post Prediction.";
"postpred.help.before.5" = "Wlacz co najmniej jedn. **metod. wprowadzania**: Siatka, OCR lub Schemat URL.";
"postpred.help.during.step.invite" = "WOLNY WYBOR";
"postpred.help.during.invite.action" = "Poprós widza, aby swobodnie pomyslal o slowie, liczbie lub literze. Nic nie sugeruj.";
"postpred.help.during.invite.dialogue" = "Pomysl o dowolnym slowie lub dowolnej liczbie. Cos osobistego, cos tylko Ty znasz. Jeszcze nie mow.";
"postpred.help.during.step.input" = "PRZECHWYTYWANIE WYBORU";
"postpred.help.during.input.action" = "Przechwyc dane wejsciowe po cichu za pomoc. Siatki, OCR lub URL, gdy widz glosno oglasza swoj wybor.";
"postpred.help.during.input.dialogue" = "Powiedz to teraz glosno, na tyle glosno, zeby wszyscy slyszeli.";
"postpred.help.during.step.reveal" = "UJAWNIENIE";
"postpred.help.during.reveal.action" = "Aplikacja odarchiwizuje odpowiednie zdjecie. W aplikacji wynik pojawia sie w ci.gu 2-3 sekund. Na prawdziwym Instagramie kazde zdjecie jest odarchiwizowane indywidualnie z krótk. pauz..";
"postpred.help.during.timing.action" = "Gdy aplikacja zawibruje, ujawnienie jest na zywo na prawdziwym Instagramie. Skieruj widza do Instagrama.";
"postpred.help.during.timing.dialogue" = "Otworz Instagram. Przejdz do mojego profilu. Przewin w dol, to bylo tam od zawsze.";
"postpred.help.tip.timing" = "**Szybkosc ujawnienia.** Jedna litera lub cyfra: ~2-3 sek. Piec liter (np. MAGIC): ~12-15 sek. Kazda kolejna litera dodaje ~2-3 sek.";
"postpred.help.tip.vibration" = "**Wibracja = gotowe.** Haptyczne sprzezenie zwrotne sygnalizuje, ze zdjecie jest na zywo na prawdziwym Instagramie.";
"postpred.help.tip.position" = "**Oryginalna pozycja.** Zdjecie pojawia sie tam, gdzie bylo w siatce, z oryginaln. dat..";
"postpred.help.tip.upload" = "**Podczas przesylania.** Nie uzywaj aplikacji, nie zmieniaj sieci Wi-Fi i nie blokuj ekranu.";
"postpred.help.tip.banks" = "**Liczba bankow.** Kazdy bank = jedna pozycja litery lub cyfry. Planuj zestawy pod katem najdluzszego slowa lub liczby, ktr. chcesz ujawnic.";
"postpred.help.tip.fakeapp" = "**Fałszywy profil = natychmiastowy podgląd, prawdziwy Instagram = po wibracjach.** Przepowiednia pojawia się w fałszywym profilu aplikacji w momencie aktywacji — ale nie jest jeszcze dostępna na prawdziwym Instagramie. Poczekaj na wibrację haptyczną przed kontynuowaniem.";
"postpred.help.tip.openprofile" = "**Najpierw otwórz swój prawdziwy profil na Instagramie.** Po tym jak wibracja potwierdzi przesłanie, otwórz swój własny profil na Instagramie zanim zaprosisz widza do spojrzenia. Dzięki temu treść zostanie załadowana w feedzie — jeśli widz odświeży wcześniej, może potrzebować przewinąć w dół, aby ją zobaczyć.";

