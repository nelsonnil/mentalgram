"perf.help.realdata.title" = "Real Instagram Data";
"perf.help.overview.body1" = "Performance is a built-in Instagram emulator. It looks and feels like the real Instagram app, but it runs inside Vault and is directly connected to your Instagram account through the official API.";
"perf.help.overview.infobox" = "Everything the spectator sees is real Instagram content from your actual account — posts, followers, reels — pulled live from the API. It is not a simulation; it is your real profile.";
"perf.help.overview.body2" = "The spectator can hold your phone, open any profile, scroll freely and see real Instagram data at all times. Vault works invisibly in the background.";
"perf.help.plus.body" = "To access Settings from Performance, tap the + button located in the top-left corner of the header bar — the same bar that shows your username in the centre. This is the only way to get back to Settings while in Performance mode.";
"perf.help.plus.infobox" = "Configure all your tricks (Force Post, Force Reel, Date Force, Counter Glitch, etc.) in Settings before the show. Once you go to Performance, use the + button to return and adjust if needed.";
"perf.help.plus.mock.label" = "Header bar";
"perf.help.plus.mock.sublabel" = "Tap + (top-left) to open Settings";
"perf.help.profile.followers.title" = "Followers count — tappable";
"perf.help.profile.followers.desc" = "Tap the followers count to open the full followers list. In Date Force mode, tap the avatar circle to select spectators — a blue number badge shows the selection order (1, 2, 3…). First half = date group, second half = time group. Tap outside the circle to open that person's profile.";
"perf.help.profile.tabs.title" = "Posts / Reels / Tagged tabs";
"perf.help.profile.tabs.desc" = "Switch between the three tabs to browse the profile's posts, reels, and tagged photos. Tap any thumbnail to see it full screen.";
"perf.help.profile.refresh.title" = "Pull to refresh";
"perf.help.profile.refresh.desc" = "Pull down on the profile to reload it from Instagram and show any recent changes (new followers, updated bio, newly uploaded photos).";
"perf.help.bottombar.body" = "The bottom navigation bar mimics Instagram's interface. Most buttons are decorative — only the magnifying glass (Search) is functional and opens Explore.";
"perf.help.bottombar.infobox" = "The Search/magnifying glass button is the main way to navigate to Explore. Tap it to browse random reels and search for any Instagram profile by username.";
"perf.help.mock.home" = "Home";
"perf.help.mock.search" = "Search";
"perf.help.mock.send" = "Send";
"perf.help.mock.profile" = "Profile";
"perf.help.mock.active" = "✓ Active";
"perf.help.mock.posts" = "Posts";
"perf.help.mock.reels" = "Reels";
"perf.help.mock.tagged" = "Tagged";
"perf.help.explore.body" = "The Explore view opens when you tap the magnifying glass in the bottom bar. It shows a real Instagram Explore feed with random reels, and a search bar at the top to find any profile.";
"perf.help.explore.reels.title" = "Random reels feed";
"perf.help.explore.reels.desc" = "Explore shows real reels from Instagram. The spectator can scroll freely. In Force Reel mode, the target reel appears at the position you dialled in secretly.";
"perf.help.explore.search.title" = "Search any real profile";
"perf.help.explore.search.desc" = "Type any username in the search bar to load their real Instagram profile — photos, followers, following — directly from the API. The spectator can freely choose who to look at.";
"perf.help.explore.infobox" = "In Force Reel mode, searching and swiping between tabs (Posts/Reels/Tagged) on a profile secretly registers each digit of the spectator's number. When you open Explore, the reel appears at exactly that position.";
"perf.help.realdata.body" = "Because Performance is connected to the real Instagram API, all data you see is authentic and current. There is no pre-loaded content.";
"perf.help.realdata.item1" = "Photos and videos are loaded live from your real Instagram account";
"perf.help.realdata.item2" = "Follower and following counts are real — and can be secretly manipulated for effects";
"perf.help.realdata.item3" = "Any profile you search loads its real posts, reels and biography from the API";
"perf.help.realdata.item4" = "Biography updates and photo uploads made from Settings appear on the real Instagram profile";

