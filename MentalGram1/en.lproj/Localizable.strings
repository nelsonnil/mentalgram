// ── Limits & Safety help (simplified) ──
"limits.help.title" = "Limits & Safety";

"limits.help.calm.title" = "Relax — everything is under control";
"limits.help.calm.body" = "Instagram occasionally shows a brief warning asking you to confirm it's you. This is completely normal for any app connected to the platform and has nothing to do with a ban. Vault is designed with the same anti-bot safeguards real apps use, and every one of them has been tested extensively.";
"limits.help.calm.infobox" = "I've personally triggered this kind of warning more than 100 times during development and my account has never been banned. Other apps with the same approach work without issues — if there were any real risk, Vault wouldn't be published.";

"limits.help.warning.title" = "If you see an \"Unusual activity\" warning";
"limits.help.warning.intro" = "Don't worry — this isn't a ban. It's just Instagram confirming it's really you. Follow these steps:";
"limits.help.warning.step1" = "Open the official Instagram app and tap \"Dismiss\" on the warning.";
"limits.help.warning.step2" = "If it asks for verification, complete it with your email or SMS code.";
"limits.help.warning.step3" = "In Vault, log out from Settings, wait about a minute, and log in again.";
"limits.help.warning.step4" = "You're ready to continue — your account is safe.";
"limits.help.warning.reassure" = "Your account keeps working perfectly. This only pauses Vault for a few minutes, nothing more.";

"limits.help.show.title" = "During a live performance";
"limits.help.show.body" = "If a warning appears while the spectator is watching the screen, Vault hides all technical details and shows a generic \"No Internet Connection\" screen.";
"limits.help.show.infobox" = "Perfect cover: \"Ugh, Instagram is glitching for a sec — no big deal.\" No spectator will see anything technical.";

"limits.help.best.title" = "Best practices";
"limits.help.best.item1" = "Don't repeat the same effect several times in a row during the same session — the algorithm may flag it as automated.";
"limits.help.best.item2" = "Prepare your sets (Sync & Archive) the night before or at least an hour before the show, not right after rehearsing.";
"limits.help.best.item3" = "If you perform often, use a dedicated Instagram account separate from your main one.";
"limits.help.best.item4" = "Vault automatically handles all wait times — you don't need to think about any of it.";

// ── Guide: Camouflage section ──
"guide.section.camouflage" = "CAMOUFLAGE";

"guide.fakehome.title" = "Fake Home Screen";
"guide.fakehome.subtitle" = "Show a home screen screenshot when Performance opens";
"guide.fakehome.help.what.title" = "What is Fake Home Screen?";
"guide.fakehome.help.what.body" = "When you open Performance, instead of going straight to your profile, the app first shows a screenshot of your real iPhone home screen. To an observer it looks like you just opened the Instagram app normally.";
"guide.fakehome.help.how.title" = "How to use it";
"guide.fakehome.help.how.body" = "1. Take a real screenshot of your iPhone home screen making sure the Instagram icon is visible.\n\n2. Upload it in Settings › Other › Fake Home Screen.\n\n3. Enable the toggle.\n\n4. Next time you open Performance, that screenshot appears full screen — tap anywhere (ideally right on the Instagram icon) to reveal your profile.";
"guide.fakehome.help.why.title" = "Why use it?";
"guide.fakehome.help.why.body" = "It creates the illusion that you are simply opening the real Instagram app. Anyone looking at your screen only sees the normal home screen before your profile appears, making the experience look completely natural.";

"guide.lockscreen.title" = "Lockscreen Input";
"guide.lockscreen.subtitle" = "Fake iOS lockscreen for secret digit entry";
"guide.lockscreen.help.what.title" = "What is Lockscreen Input?";
"guide.lockscreen.help.what.body" = "When you open Performance, the app shows a fake iOS-style passcode screen before revealing your profile. To anyone watching it looks like you are simply unlocking your phone.";
"guide.lockscreen.help.how.title" = "How to enter your secret number";
"guide.lockscreen.help.how.body" = "1. Tap the digits of your secret number on the numpad — they register silently.\n\n2. Tap anywhere outside the numpad to lock those digits in place.\n\n3. Fill the remaining dots by tapping any digits — they are ignored.\n\n4. Once all 4 dots are filled the lockscreen dismisses and Performance opens.";
"guide.lockscreen.help.wallpaper.title" = "Wallpaper";
"guide.lockscreen.help.wallpaper.body" = "Upload the same wallpaper you use on your real lock screen so the fake one looks identical. Without a wallpaper the lockscreen input cannot be enabled.";
"guide.lockscreen.help.why.title" = "Why use it?";
"guide.lockscreen.help.why.body" = "It disguises the act of entering a secret number as a normal phone unlock. Combined with Fake Home Screen, the full sequence looks like: unlock phone → home screen → open Instagram — completely natural to any observer.";
"guide.lockscreen.help.tricks.title" = "Same secret number — many tricks";
"guide.lockscreen.help.tricks.body" = "The number you enter here is the same secret number used by the Grid Input and all other magic tricks. With it you can trigger:\n\n• Unarchive a photo from a numeric set\n• Reveal a playing card\n• Show a custom image\n• Activate counter glitch\n• Force a reel in Explore";
"guide.lockscreen.help.cards.title" = "Playing Card codes";
"guide.lockscreen.help.cards.body" = "To reveal a playing card, enter its code as the secret number:\n\nSuits:  1 = ♠   2 = ♥   3 = ♣   4 = ♦\n\nCards A–9  →  [value][suit]\n  A♠ = 11    7♥ = 72    9♦ = 94\n\nCards 10, J, Q, K  →  [tens][units][suit]\n  10♠ = 101    J♥ = 112\n  Q♣  = 123    K♦  = 134\n\nExample: to reveal Q♥ enter 122.";
