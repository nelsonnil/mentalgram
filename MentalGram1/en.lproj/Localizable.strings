"postpred.help.nav.title" = "Post Prediction";
"postpred.help.nav.subtitle" = "Performance Guide";
"postpred.help.hero.title" = "The Image Prediction";
"postpred.help.hero.body" = "A selected image appears on your Instagram profile — in its exact original position, with its original date — chosen in real time by the spectator.";
"postpred.help.section.howitworks" = "How It Works";
"postpred.help.section.inputs" = "Input Methods";
"postpred.help.section.before" = "Before the Show";
"postpred.help.section.during" = "During the Show";
"postpred.help.section.tips" = "Tips";
"postpred.help.section.settypes" = "Set Types";
"postpred.help.settypes.intro" = "Choose the type that matches your effect:";
"postpred.help.settype.word.desc" = "**26 slots (A–Z) × N banks.** Each bank reveals one letter. Bank 1 = 1st letter, Bank 2 = 2nd letter.";
"postpred.help.settype.number.desc" = "**10 slots (0–9) × N banks.** Each bank reveals one digit. Bank 1 = 1st digit, Bank 2 = 2nd digit.";
"postpred.help.settype.custom.desc" = "**1–100 custom images, 1 bank.** Swipe 1–3 digits to select the slot number (1–100). Perfect for match results, tarot draws, or any visual choice.";
"postpred.help.settype.card.desc" = "**52 slots (A–K × ♠♥♣♦), 1 bank.** Swipe 2 or 3 digits to select any card. Suits: 1=♠ 2=♥ 3=♣ 4=♦. Example: 4→2 = 4♥ · 1→1→1 = J♠.";
"postpred.help.howitworks.step1" = "Prepare your **Set** — upload photos in advance and let the app archive them automatically. They become invisible on Instagram until you choose to reveal them.";
"postpred.help.howitworks.step2" = "The spectator freely picks a word, number, image, or card. You capture their choice silently using one of the input methods.";
"postpred.help.howitworks.step3" = "Trigger the reveal. The matching photo reappears on real Instagram **in its original position, with its original date** — as if it had always been there.";
"postpred.help.howitworks.info" = "The spectator sees a real post on a real Instagram profile. There is no app involved — just Instagram.";
"postpred.help.metric.sets" = "Sets";
"postpred.help.metric.sets.desc" = "Collections of photos (letters A–Z or digits 0–9) uploaded and archived in advance, ready to be revealed.";
"postpred.help.metric.banks" = "Banks";
"postpred.help.metric.banks.desc" = "Each bank = one position in the word or number. Bank 1 → first letter/digit, Bank 2 → second, and so on. The number of banks defines the maximum length of what you can reveal.";
"postpred.help.inputs.intro" = "Each input method is compatible with specific set types. Choose the one that best fits your performance.";
"postpred.help.input.grid.label" = "GRID INPUT";
"postpred.help.input.grid.intro" = "In Performance, swipe left or right across the photo grid. Posts 1–9 map to digits 1–9; posts 10 or higher map to digit 0. Accumulate up to 3 digits, then tap the Posts icon to trigger the reveal.";
"postpred.help.input.grid.case.number" = "Each digit selects the slot in its bank — bank 1 → 1st digit, bank 2 → 2nd digit, and so on.";
"postpred.help.input.grid.case.custom" = "All accumulated digits form the slot number (1–100). E.g. swipe 7 then 2 = slot 72. Swipe 1, 0, 0 = slot 100.";
"postpred.help.input.grid.case.card" = "2 digits: [value + suit]. 3 digits: [tens + units + suit]. Suits: 1=♠  2=♥  3=♣  4=♦. E.g. 4→2 = 4♥ · 1→1→1 = J♠.";
"postpred.help.input.grid.step3" = "Tap the Posts icon to confirm and trigger the reveal.";
"postpred.help.input.ocr.label" = "OCR — CAMERA";
"postpred.help.input.ocr.step1" = "Enable **OCR** in Post Prediction settings.";
"postpred.help.input.ocr.step2" = "Point the camera at any handwritten or printed word. The app reads it automatically and triggers the matching reveal.";
"postpred.help.input.covert.label" = "COVERT TYPING";
"postpred.help.input.covert.step1" = "Enable **Covert Typing** in Post Prediction settings and define a cover word — what the spectator will see.";
"postpred.help.input.covert.step2" = "Type the spectator's word in the Explore search field. The spectator sees the cover word; the app silently records the real one.";
"postpred.help.input.covert.step3" = "Press **Space once** when done. The space vanishes from the field — this is intentional. A subtle vibration confirms the word was captured and the reveal is triggered.";
"postpred.help.input.url.label" = "URL SCHEME / AUTOMATION";
"postpred.help.input.url.intro" = "Trigger the reveal remotely from any automation tool — Apple Shortcuts, NFC tags, QR codes, or companion apps. Supports all set types.";
"postpred.help.input.url.example.word" = "Word Reveal";
"postpred.help.input.url.example.slot" = "Custom Set — slot number (1–100)";
"postpred.help.input.url.example.card" = "Playing Cards — card symbol (e.g. J♠, 10♥, K♦)";
"postpred.help.before.1" = "Create a **Set** in the Sets section. Choose Word Reveal, Number Reveal, Custom Set, or Playing Cards. Select an image template or upload your own photos.";
"postpred.help.before.2" = "Upload the images and wait for them to be **automatically archived**. This can take several hours — leave the app running overnight if needed.";
"postpred.help.before.3" = "During upload, **do not use the app**, change networks, or interrupt the process. The screen stays awake automatically. A notification will prompt you to return between uploads.";
"postpred.help.before.4" = "Set the uploaded Set as **active** in Post Prediction settings.";
"postpred.help.before.5" = "Enable at least one **input method**: Grid Input, OCR, or URL Scheme.";
"postpred.help.during.step.invite" = "THE FREE CHOICE";
"postpred.help.during.invite.action" = "Ask the spectator to freely think of a word, number, or letter. Do not suggest anything.";
"postpred.help.during.invite.dialogue" = "\"Think of any word — or any number. Something personal, something only you know. Don't say it yet.\"";
"postpred.help.during.step.input" = "CAPTURING THE CHOICE";
"postpred.help.during.input.action" = "Capture the input silently using Grid Input, OCR, or URL Scheme, while the spectator speaks their choice aloud.";
"postpred.help.during.input.dialogue" = "\"Say it out loud now — loud enough for everyone to hear.\"";
"postpred.help.during.step.reveal" = "THE REVEAL";
"postpred.help.during.reveal.action" = "The app unarchives the matching photo. In the app, the result appears within 2–3 seconds. On real Instagram, each photo is unarchived individually with a short pause — total time depends on the length of the word.";
"postpred.help.during.timing.action" = "When the app vibrates, the reveal is live on real Instagram. Direct the spectator to open Instagram.";
"postpred.help.during.timing.dialogue" = "\"Open Instagram. Go to my profile. Scroll down — it was there all along.\"";
"postpred.help.tip.timing" = "**Reveal speed.** One letter or digit: ~2–3 seconds. Five letters (e.g. 'MAGIC'): ~12–15 seconds. Each additional letter adds ~2–3 seconds.";
"postpred.help.tip.vibration" = "**Vibration = ready.** The haptic feedback is the signal that the photo is live on real Instagram. Once it vibrates, direct the spectator to scroll their profile.";
"postpred.help.tip.position" = "**Original position.** The photo reappears exactly where it was in the grid, with its original date — it may require scrolling to find it.";
"postpred.help.tip.upload" = "**During upload.** Do not use the app, change Wi-Fi networks, or let the screen lock. A notification prompts you to return between each upload.";
"postpred.help.tip.banks" = "**Number of Banks.** Each bank = one letter or digit position. Plan your sets around the longest word or number you want to reveal.";
"postpred.help.tip.fakeapp" = "**Fake profile = instant preview, real Instagram = after vibration.** The prediction appears in the app's fake profile the moment it is triggered — but it is not yet live on real Instagram. Wait for the haptic vibration before proceeding.";
"postpred.help.tip.openprofile" = "**Open your real Instagram profile first.** After the vibration confirms the upload, open your own Instagram profile before inviting the spectator to look. This loads the content in the feed — if the spectator refreshes first, they may need to scroll down to see it.";
"postpred.help.inputs.group.numeric" = "FOR NUMBER, CUSTOM & CARD SETS";
"postpred.help.inputs.group.alpha" = "FOR ALPHABETIC SETS";
"postpred.help.inputs.group.universal" = "UNIVERSAL — ALL SET TYPES";
"postpred.help.input.api.label" = "API / AUTOMATION";
"postpred.help.input.api.step1" = "Use an external automation tool (Shortcuts, NFC tag, companion app) to send the word or number to Post Prediction via URL scheme.";
"postpred.help.input.api.step2" = "Useful when a third-party trigger or physical prop automatically fires the reveal at the right moment.";
