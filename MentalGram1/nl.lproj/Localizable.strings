"postpred.help.howitworks.step1" = "Bereid uw **Set** voor — upload foto's van tevoren en laat de app ze automatisch archiveren. Ze worden onzichtbaar op Instagram totdat u ze wilt onthullen.";
"postpred.help.howitworks.step2" = "De toeschouwer kiest vrij een woord, getal, afbeelding of kaart. U legt zijn keuze stil vast met een van de invoermethoden.";
"postpred.help.howitworks.step3" = "Activeer de onthulling. De bijbehorende foto verschijnt op echt Instagram **op zijn oorspronkelijke positie, met zijn oorspronkelijke datum** — alsof hij er altijd al was.";
"postpred.help.howitworks.body1" = "U bereidt een **Set** voor, een verzameling fotos, een voor elke letter of cijfer. De fotos worden van tevoren geupload en automatisch gearchiveerd, zodat ze onzichtbaar zijn op Instagram totdat u ze wilt onthullen.";
"postpred.help.howitworks.body2" = "Wanneer u de onthulling activeert, dearchiveert de app de bijbehorende foto. Deze verschijnt op zijn **oorspronkelijke rasterpositie** met zijn **oorspronkelijke datum**, alsof hij er altijd al was.";
"postpred.help.howitworks.info" = "De toeschouwer ziet een echte post op een echt Instagram-profiel. Er is geen app zichtbaar, alleen Instagram.";
"postpred.help.metric.sets" = "Sets";
"postpred.help.metric.sets.desc" = "Fotoverzamelingen die van tevoren zijn geupload en gearchiveerd. Klaar voor onthulling.";
"postpred.help.metric.banks" = "Banken";
"postpred.help.metric.banks.desc" = "Elke bank = een positie in het woord of getal. Bank 1 -> eerste letter, Bank 2 -> tweede letter. Het aantal banken bepaalt de maximale lengte van wat u kunt onthullen.";
"postpred.help.inputs.body1" = "De toeschouwer denkt vrij aan een woord of getal. U legt zijn keuze stil vast met een van drie methoden:";
"postpred.help.inputs.intro" = "Elke invoermethode is compatibel met specifieke set-typen. Kies de methode die het beste past bij uw optreden.";
"postpred.help.input.grid.label" = "RASTERINVOER";
"postpred.help.input.grid.intro" = "Veeg in de voorstelling links of rechts over het fotoraster. Posts 1–9 komen overeen met de cijfers 1–9; posts 10+ met het cijfer 0. Verzamel maximaal 3 cijfers en tik op het Posts-pictogram om te onthullen.";
"postpred.help.input.grid.case.number" = "Elk cijfer selecteert de slot in zijn bank — bank 1 → 1e cijfer, bank 2 → 2e cijfer, enzovoort.";
"postpred.help.input.grid.case.custom" = "Alle verzamelde cijfers vormen het slotnummer (1–100). Bijv.: veeg 7 dan 2 = slot 72. Veeg 1, 0, 0 = slot 100.";
"postpred.help.input.grid.case.card" = "2 cijfers: [waarde + kleur]. 3 cijfers: [tiental + eenheid + kleur]. Kleuren: 1=♠  2=♥  3=♣  4=♦. Bijv.: 4→2 = 4♥ · 1→1→1 = J♠.";
"postpred.help.input.grid.step1" = "Schakel **Cijferraster** in bij de Post Prediction-instellingen.";
"postpred.help.input.grid.step2" = "Veeg in Prestaties links of rechts over het fotoraster. Posts 1-9 komen overeen met de cijfers 1-9. Posts 10, 11 en 12 komen overeen met het cijfer 0.";
"postpred.help.input.grid.step3" = "Tik op het Posts-pictogram om te bevestigen en de onthulling te activeren.";
"postpred.help.input.ocr.label" = "OCR — CAMERA";
"postpred.help.input.covert.label" = "VERBORGEN INVOER";
"postpred.help.input.covert.step1" = "Schakel **Verborgen invoer** in de instellingen in en stel een dekwoord in — wat de toeschouwer op het scherm ziet.";
"postpred.help.input.covert.step2" = "Typ het woord van de toeschouwer in het Explore-zoekveld. De toeschouwer ziet het dekwoord; de app registreert het echte woord stil.";
"postpred.help.input.covert.step3" = "Druk éénmaal op **Spatie** als u klaar bent. De spatie verdwijnt uit het veld — dit is normaal. Een subtiele trilling bevestigt dat het woord is vastgelegd en de onthulling is geactiveerd.";
"postpred.help.input.url.label" = "URL SCHEME / AUTOMATISERING";
"postpred.help.input.url.intro" = "Activeer de onthulling op afstand vanuit elke automatiseringstool — Apple Opdrachten, NFC-tags, QR-codes of companion-apps. Compatibel met alle set-typen.";
"postpred.help.input.url.example.word" = "Word Reveal";
"postpred.help.input.url.example.slot" = "Custom Set — slotnummer (1–100)";
"postpred.help.input.url.example.card" = "Playing Cards — kaartsymbool (bijv. J♠, 10♥, K♦)";
"postpred.help.settype.word.desc" = "**26 slots (A–Z) × N banken.** Elke bank onthult een letter. Bank 1 = 1e letter, Bank 2 = 2e letter.";
"postpred.help.settype.number.desc" = "**10 slots (0–9) × N banken.** Elke bank onthult een cijfer. Bank 1 = 1e cijfer, Bank 2 = 2e cijfer.";
"postpred.help.settype.custom.desc" = "**1–100 eigen afbeeldingen, 1 bank.** Veeg 1–3 cijfers om het slotnummer (1–100) te kiezen. Ideaal voor wedstrijduitslagen, tarot of visuele keuzes.";
"postpred.help.settype.card.desc" = "**52 slots (A–K × ♠♥♣♦), 1 bank.** Veeg 2 of 3 cijfers om een kaart te kiezen. Kleuren: 1=♠ 2=♥ 3=♣ 4=♦. Bijv.: 4→2 = 4♥ · 1→1→1 = J♠.";
"postpred.help.input.ocr.step1" = "Schakel **OCR** in bij de Post Prediction-instellingen.";
"postpred.help.input.ocr.step2" = "Richt de camera op een handgeschreven of gedrukt woord. De app leest het automatisch en activeert de bijbehorende onthulling.";
"postpred.help.input.url.label" = "URL-SCHEMA";
"postpred.help.input.url.step1" = "Schakel **URL Scheme** in bij de Post Prediction-instellingen.";
"postpred.help.input.url.step2" = "Activeer de onthulling op afstand via een aangepaste URL. Handig met NFC-tags, QR-codes of automatiseringssnelkoppelingen.";
"postpred.help.before.1" = "Maak een **Set** aan in de Sets-sectie. Kies Word Reveal, Number Reveal, Custom Set of Playing Cards. Selecteer een afbeeldingssjabloon of upload uw eigen foto's.";
"postpred.help.before.2" = "Upload de afbeeldingen en wacht tot ze **automatisch zijn gearchiveerd**. Dit kan enkele uren duren.";
