// ── Performance Help View ──
"How the Instagram emulator works — navigation, profiles and Explore" = "Hoe de Instagram-emulator werkt — navigatie, profielen en Verkennen";
"perf.help.overview.title" = "Wat is Performance?";
"perf.help.plus.title" = "De + knop — Instellingen openen";
"perf.help.profile.title" = "De profielweergave";
"perf.help.bottombar.title" = "Onderste navigatiebalk";
"perf.help.explore.title" = "Verkennen";
"perf.help.realdata.title" = "Echte Instagram-gegevens";
"perf.help.overview.body1" = "Performance is een ingebouwde Instagram-emulator. Het ziet eruit en werkt als de echte Instagram-app, maar het draait binnen Vault en is rechtstreeks verbonden met je Instagram-account via de officiële API.";
"perf.help.overview.infobox" = "Alles wat de toeschouwer ziet is echte Instagram-inhoud van je werkelijke account — berichten, volgers, reels — live opgehaald uit de API. Het is geen simulatie; het is je echte profiel.";
"perf.help.overview.body2" = "De toeschouwer kan je telefoon vasthouden, elk profiel openen, vrij scrollen en op elk moment echte Instagram-gegevens zien. Vault werkt onzichtbaar op de achtergrond.";
"perf.help.plus.body" = "Om Instellingen te openen vanuit Performance, tik op de + knop linksboven in de kopbalk — dezelfde balk die je gebruikersnaam in het midden toont. Dit is de enige manier om terug te gaan naar Instellingen in de Performance-modus.";
"perf.help.plus.infobox" = "Configureer alle trucs (Force Post, Force Reel, Date Force, Counter Glitch, etc.) in Instellingen voor de show. Eenmaal in Performance, gebruik de + knop om terug te gaan en indien nodig aan te passen.";
"perf.help.plus.mock.label" = "Kopbalk";
"perf.help.plus.mock.sublabel" = "Tik + (linksboven) om Instellingen te openen";
"perf.help.profile.followers.title" = "Volgersteller — aantikbaar";
"perf.help.profile.followers.desc" = "Tik op het volgersteller om de volledige lijst te openen. In Date Force-modus tik je op de avatarcirkel om toeschouwers te selecteren — een blauw getal (1, 2, 3…) toont de selectievolgorde. Eerste helft = datumgroep, tweede helft = tijdgroep. Tik buiten de cirkel om het profiel van die persoon te openen.";
"perf.help.profile.tabs.title" = "Berichten / Reels / Getagd tabbladen";
"perf.help.profile.tabs.desc" = "Schakel tussen de drie tabbladen om de berichten, reels en getagde foto's van het profiel te bekijken. Tik op een miniatuur om het op volledig scherm te zien.";
"perf.help.profile.refresh.title" = "Trek om te vernieuwen";
"perf.help.profile.refresh.desc" = "Trek het profiel naar beneden om het opnieuw te laden van Instagram en recente wijzigingen te tonen (nieuwe volgers, bijgewerkte bio, nieuw geüploade foto's).";
"perf.help.bottombar.body" = "De onderste navigatiebalk imiteert de interface van Instagram. De meeste knoppen zijn decoratief — alleen het vergrootglas (Zoeken) is functioneel en opent Verkennen.";
"perf.help.bottombar.infobox" = "De Zoek/vergrootglas knop is de belangrijkste manier om naar Verkennen te navigeren. Tik om willekeurige reels te bekijken en naar elk Instagram-profiel op gebruikersnaam te zoeken.";
"perf.help.mock.home" = "Home";
"perf.help.mock.search" = "Zoeken";
"perf.help.mock.send" = "Verzenden";
"perf.help.mock.profile" = "Profiel";
"perf.help.mock.active" = "✓ Actief";
"perf.help.mock.posts" = "Berichten";
"perf.help.mock.reels" = "Reels";
"perf.help.mock.tagged" = "Getagd";
"perf.help.explore.body" = "De Verkennen-weergave opent wanneer je op het vergrootglas in de onderste balk tikt. Het toont een echte Instagram Verkennen-feed met willekeurige reels en een zoekbalk bovenaan om elk profiel te vinden.";
"perf.help.explore.reels.title" = "Willekeurige reels-feed";
"perf.help.explore.reels.desc" = "Verkennen toont echte reels van Instagram. De toeschouwer kan vrij scrollen. In Force Reel-modus verschijnt de doelreel op de positie die je in het geheim hebt ingedraaid.";
"perf.help.explore.search.title" = "Elk echt profiel zoeken";
"perf.help.explore.search.desc" = "Typ een gebruikersnaam in de zoekbalk om hun echte Instagram-profiel te laden — foto's, volgers, volgend — rechtstreeks van de API. De toeschouwer kan vrij kiezen wie ze willen bekijken.";
"perf.help.explore.infobox" = "In Force Reel-modus registreert het zoeken en vegen tussen tabbladen (Berichten/Reels/Getagd) op een profiel stiekem elk cijfer van het getal van de toeschouwer. Wanneer je Verkennen opent, verschijnt de reel precies op die positie.";
"perf.help.realdata.body" = "Omdat Performance verbonden is met de echte Instagram API, zijn alle gegevens die je ziet authentiek en actueel. Er is geen vooraf geladen inhoud.";
"perf.help.realdata.item1" = "Foto's en video's worden live geladen van je echte Instagram-account";
"perf.help.realdata.item2" = "Volger- en volgendtellers zijn echt — en kunnen stiekem worden gemanipuleerd voor effecten";
"perf.help.realdata.item3" = "Elk profiel dat je zoekt laadt zijn echte berichten, reels en biografie van de API";
"perf.help.realdata.item4" = "Biografie-updates en foto-uploads vanuit Instellingen verschijnen op het echte Instagram-profiel";

