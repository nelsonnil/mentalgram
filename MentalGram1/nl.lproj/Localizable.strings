// Post Prediction Help
"postpred.help.nav.title" = "Post Prediction";
"postpred.help.nav.subtitle" = "Prestatiegids";
"postpred.help.hero.title" = "De beeldvoorspelling";
"postpred.help.hero.body" = "Een geselecteerde afbeelding verschijnt op uw Instagram-profiel op zijn exacte oorspronkelijke positie, met de oorspronkelijke datum, in realtime gekozen door de toeschouwer.";
"postpred.help.section.howitworks" = "Hoe het werkt";
"postpred.help.section.inputs" = "Invoermethoden";
"postpred.help.section.before" = "Voor de show";
"postpred.help.section.during" = "Tijdens de show";
"postpred.help.section.tips" = "Tips";
"postpred.help.howitworks.body1" = "U bereidt een **Set** voor, een verzameling fotos, een voor elke letter of cijfer. De fotos worden van tevoren geupload en automatisch gearchiveerd, zodat ze onzichtbaar zijn op Instagram totdat u ze wilt onthullen.";
"postpred.help.howitworks.body2" = "Wanneer u de onthulling activeert, dearchiveert de app de bijbehorende foto. Deze verschijnt op zijn **oorspronkelijke rasterpositie** met zijn **oorspronkelijke datum**, alsof hij er altijd al was.";
"postpred.help.howitworks.info" = "De toeschouwer ziet een echte post op een echt Instagram-profiel. Er is geen app zichtbaar, alleen Instagram.";
"postpred.help.metric.sets" = "Sets";
"postpred.help.metric.sets.desc" = "Fotoverzamelingen die van tevoren zijn geupload en gearchiveerd. Klaar voor onthulling.";
"postpred.help.metric.banks" = "Banken";
"postpred.help.metric.banks.desc" = "Elke bank = een positie in het woord of getal. Bank 1 -> eerste letter, Bank 2 -> tweede letter. Het aantal banken bepaalt de maximale lengte van wat u kunt onthullen.";
"postpred.help.inputs.body1" = "De toeschouwer denkt vrij aan een woord of getal. U legt zijn keuze stil vast met een van drie methoden:";
"postpred.help.input.grid.label" = "RASTERINVOER";
"postpred.help.input.grid.step1" = "Schakel **Cijferraster** in bij de Post Prediction-instellingen.";
"postpred.help.input.grid.step2" = "Veeg in Prestaties links of rechts over het fotoraster. Posts 1-9 komen overeen met de cijfers 1-9. Posts 10, 11 en 12 komen overeen met het cijfer 0.";
"postpred.help.input.grid.step3" = "Tik op het Posts-pictogram om te bevestigen en de onthulling te activeren.";
"postpred.help.input.ocr.label" = "OCR - CAMERAHERKENNING";
"postpred.help.input.ocr.step1" = "Schakel **OCR** in bij de Post Prediction-instellingen.";
"postpred.help.input.ocr.step2" = "Richt de camera op een handgeschreven of gedrukt woord. De app leest het automatisch en activeert de bijbehorende onthulling.";
"postpred.help.input.url.label" = "URL-SCHEMA";
"postpred.help.input.url.step1" = "Schakel **URL Scheme** in bij de Post Prediction-instellingen.";
"postpred.help.input.url.step2" = "Activeer de onthulling op afstand via een aangepaste URL. Handig met NFC-tags, QR-codes of automatiseringssnelkoppelingen.";
"postpred.help.before.1" = "Maak een **Set** aan in de Sets-sectie. Kies het lettertype en selecteer een afbeeldingssjabloon of upload uw eigen fotos.";
"postpred.help.before.2" = "Upload de afbeeldingen en wacht tot ze **automatisch zijn gearchiveerd**. Dit kan enkele uren duren.";
"postpred.help.before.3" = "Tijdens het uploaden **gebruikt u de app niet**, wisselt u niet van netwerk en onderbreekt u het proces niet. Het scherm blijft automatisch aan.";
"postpred.help.before.4" = "Stel de geuploadede Set in als **actief** in de Post Prediction-instellingen.";
"postpred.help.before.5" = "Schakel ten minste een **invoermethode** in: Raster, OCR of URL-schema.";
"postpred.help.during.step.invite" = "DE VRIJE KEUZE";
"postpred.help.during.invite.action" = "Vraag de toeschouwer vrij aan een woord, getal of letter te denken. Suggereer niets.";
"postpred.help.during.invite.dialogue" = "Denk aan een willekeurig woord of getal. Iets persoonlijks, iets alleen u weet. Zeg het nog niet.";
"postpred.help.during.step.input" = "DE KEUZE VASTLEGGEN";
"postpred.help.during.input.action" = "Leg de invoer stil vast met Raster, OCR of URL, terwijl de toeschouwer zijn keuze hardop uitspreekt.";
"postpred.help.during.input.dialogue" = "Zeg het nu hardop, luid genoeg zodat iedereen het hoort.";
"postpred.help.during.step.reveal" = "DE ONTHULLING";
"postpred.help.during.reveal.action" = "De app dearchiveert de bijbehorende foto. In de app verschijnt het resultaat binnen 2-3 seconden. Op echt Instagram wordt elke foto afzonderlijk gedearchiveerd met een korte pauze.";
"postpred.help.during.timing.action" = "Wanneer de app trilt, is de onthulling live op echt Instagram. Begeleid de toeschouwer naar Instagram.";
"postpred.help.during.timing.dialogue" = "Open Instagram. Ga naar mijn profiel. Scroll naar beneden, het was er altijd al.";
"postpred.help.tip.timing" = "**Onthullingssnelheid.** Een letter of cijfer: ~2-3 sec. Vijf letters (bijv. MAGIC): ~12-15 sec. Elke extra letter voegt ~2-3 sec toe.";
"postpred.help.tip.vibration" = "**Trillen = klaar.** De haptische feedback signaleert dat de foto live is op echt Instagram. Begeleid de toeschouwer na het trillen.";
"postpred.help.tip.position" = "**Oorspronkelijke positie.** De foto verschijnt op exact dezelfde plek in het raster met de oorspronkelijke datum.";
"postpred.help.tip.upload" = "**Tijdens het uploaden.** Gebruik de app niet, wissel niet van Wi-Fi-netwerk en vergrendel het scherm niet.";
"postpred.help.tip.banks" = "**Aantal banken.** Elke bank = een letter- of cijferpositie. Plan uw sets op basis van het langste woord of getal dat u wilt onthullen.";
"postpred.help.tip.fakeapp" = "**Nepprofiel = directe preview, echt Instagram = na de trilling.** De voorspelling verschijnt meteen in het nepprofiel van de app — maar staat nog niet op echt Instagram. Wacht op de haptische feedback voordat je verdergaat.";
"postpred.help.tip.openprofile" = "**Open eerst je echte Instagram-profiel.** Nadat de trilling de upload bevestigt, open je eigen Instagram-profiel voordat je de toeschouwer uitnodigt te kijken. Dit laadt de inhoud in de feed — als de toeschouwer eerst ververst, moet hij mogelijk naar beneden scrollen om het te zien.";

