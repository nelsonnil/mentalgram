"postpred.help.hero.title" = "La prediccion de imagen";
"postpred.help.hero.body" = "Una imagen seleccionada aparece en tu perfil de Instagram en su posicion original exacta, con su fecha original, elegida en tiempo real por el espectador.";
"postpred.help.section.howitworks" = "Como funciona";
"postpred.help.section.inputs" = "Metodos de entrada";
"postpred.help.section.before" = "Antes del show";
"postpred.help.section.during" = "Durante el show";
