// ── Performance Help View ──
"How the Instagram emulator works — navigation, profiles and Explore" = "Cómo funciona el emulador de Instagram — navegación, perfiles y Explore";
"perf.help.overview.title" = "¿Qué es Performance?";
"perf.help.plus.title" = "El botón + — Acceder a Ajustes";
"perf.help.profile.title" = "La vista de perfil";
"perf.help.bottombar.title" = "Barra de navegación inferior";
"perf.help.explore.title" = "Explore";
"perf.help.realdata.title" = "Datos reales de Instagram";
"perf.help.overview.body1" = "Performance es un emulador de Instagram integrado. Tiene el aspecto y el funcionamiento de la app real de Instagram, pero se ejecuta dentro de Vault y está conectado directamente a tu cuenta de Instagram a través de la API oficial.";
"perf.help.overview.infobox" = "Todo lo que ve el espectador es contenido real de Instagram de tu cuenta real — publicaciones, seguidores, reels — obtenido en directo desde la API. No es una simulación; es tu perfil real.";
"perf.help.overview.body2" = "El espectador puede coger tu móvil, abrir cualquier perfil, desplazarse libremente y ver datos reales de Instagram en todo momento. Vault funciona de forma invisible en segundo plano.";
"perf.help.plus.body" = "Para acceder a Ajustes desde Performance, pulsa el botón + situado en la esquina superior izquierda de la barra de cabecera — la misma barra que muestra tu nombre de usuario en el centro. Es la única forma de volver a Ajustes mientras estás en modo Performance.";
"perf.help.plus.infobox" = "Configura todos tus trucos (Force Post, Force Reel, Date Force, Counter Glitch, etc.) en Ajustes antes del show. Una vez en Performance, usa el botón + para volver y ajustar si es necesario.";
"perf.help.plus.mock.label" = "Barra de cabecera";
"perf.help.plus.mock.sublabel" = "Toca + (arriba a la izquierda) para abrir Ajustes";
"perf.help.profile.followers.title" = "Contador de seguidores — pulsable";
"perf.help.profile.followers.desc" = "Pulsa el contador de seguidores para abrir la lista completa. En el modo Date Force, toca el círculo del avatar para seleccionar espectadores — aparece un número azul (1, 2, 3…) que indica el orden de selección. La primera mitad = grupo fecha, la segunda mitad = grupo hora. Toca fuera del círculo para abrir el perfil de esa persona.";
"perf.help.profile.tabs.title" = "Pestañas Posts / Reels / Etiquetados";
"perf.help.profile.tabs.desc" = "Cambia entre las tres pestañas para explorar los posts, reels y fotos etiquetadas del perfil. Pulsa cualquier miniatura para verla en pantalla completa.";
"perf.help.profile.refresh.title" = "Desliza para actualizar";
"perf.help.profile.refresh.desc" = "Desliza hacia abajo en el perfil para recargarlo desde Instagram y mostrar los cambios recientes (nuevos seguidores, bio actualizada, fotos recién subidas).";
"perf.help.bottombar.body" = "La barra de navegación inferior imita la interfaz de Instagram. La mayoría de los botones son decorativos — solo la lupa (Buscar) es funcional y abre Explore.";
"perf.help.bottombar.infobox" = "El botón Buscar/lupa es la principal forma de navegar a Explore. Pulsa para explorar reels aleatorios y buscar cualquier perfil de Instagram por nombre de usuario.";
"perf.help.mock.home" = "Inicio";
"perf.help.mock.search" = "Buscar";
"perf.help.mock.send" = "Enviar";
"perf.help.mock.profile" = "Perfil";
"perf.help.mock.active" = "✓ Activo";
"perf.help.mock.posts" = "Posts";
"perf.help.mock.reels" = "Reels";
"perf.help.mock.tagged" = "Etiquetados";
"perf.help.explore.body" = "La vista Explore se abre al pulsar la lupa en la barra inferior. Muestra un feed real de Instagram Explore con reels aleatorios y una barra de búsqueda en la parte superior para encontrar cualquier perfil.";
"perf.help.explore.reels.title" = "Feed de reels aleatorios";
"perf.help.explore.reels.desc" = "Explore muestra reels reales de Instagram. El espectador puede desplazarse libremente. En el modo Force Reel, el reel objetivo aparece en la posición que marcaste en secreto.";
"perf.help.explore.search.title" = "Buscar cualquier perfil real";
"perf.help.explore.search.desc" = "Escribe cualquier nombre de usuario en la barra de búsqueda para cargar su perfil real de Instagram — fotos, seguidores, seguidos — directamente desde la API. El espectador puede elegir libremente a quién ver.";
"perf.help.explore.infobox" = "En el modo Force Reel, buscar y deslizarse entre pestañas (Posts/Reels/Etiquetados) en un perfil registra en secreto cada dígito del número del espectador. Al abrir Explore, el reel aparece exactamente en esa posición.";
"perf.help.realdata.body" = "Dado que Performance está conectado a la API real de Instagram, todos los datos que ves son auténticos y actuales. No hay contenido precargado.";
"perf.help.realdata.item1" = "Las fotos y vídeos se cargan en directo desde tu cuenta real de Instagram";
"perf.help.realdata.item2" = "Los contadores de seguidores y seguidos son reales — y pueden manipularse en secreto para los efectos";
"perf.help.realdata.item3" = "Cualquier perfil que busques carga sus posts, reels y biografía reales desde la API";
"perf.help.realdata.item4" = "Las actualizaciones de la biografía y las subidas de fotos realizadas desde Ajustes aparecen en el perfil real de Instagram";

