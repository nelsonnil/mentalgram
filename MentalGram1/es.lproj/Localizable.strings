// Post Prediction Help
"postpred.help.nav.title" = "Post Prediction";
"postpred.help.nav.subtitle" = "Guia de actuacion";
"postpred.help.hero.title" = "La prediccion de imagen";
"postpred.help.hero.body" = "Una imagen seleccionada aparece en tu perfil de Instagram en su posicion original exacta, con su fecha original, elegida en tiempo real por el espectador.";
"postpred.help.section.howitworks" = "Como funciona";
"postpred.help.section.inputs" = "Metodos de entrada";
"postpred.help.section.before" = "Antes del show";
"postpred.help.section.during" = "Durante el show";
"postpred.help.section.tips" = "Consejos";
"postpred.help.howitworks.body1" = "Preparas un **Set** de fotos, una por cada letra o digito. Las fotos se suben de antemano y se archivan automaticamente, por lo que son invisibles en Instagram hasta que decides revelarlas.";
"postpred.help.howitworks.body2" = "Al activar la revelacion, la app desarchiva la foto correspondiente. Reaparece en su **posicion original en la cuadricula**, con su **fecha original**, como si siempre hubiera estado ahi.";
"postpred.help.howitworks.info" = "El espectador ve una publicacion real en un perfil real de Instagram. No hay app visible, solo Instagram.";
"postpred.help.metric.sets" = "Sets";
"postpred.help.metric.sets.desc" = "Colecciones de fotos (letras A-Z o digitos 0-9) subidas y archivadas de antemano, listas para ser reveladas.";
"postpred.help.metric.banks" = "Bancos";
"postpred.help.metric.banks.desc" = "Cada banco = una posicion en la palabra o numero. Banco 1 -> primera letra, Banco 2 -> segunda letra, y asi sucesivamente. El numero de bancos define la longitud maxima de lo que puedes revelar.";
"postpred.help.inputs.body1" = "El espectador piensa libremente en una palabra o numero. Capturas su eleccion en silencio usando uno de tres metodos:";
"postpred.help.input.grid.label" = "ENTRADA POR CUADRICULA";
"postpred.help.input.grid.step1" = "Activa **Cuadricula de digitos** en los ajustes de Post Prediction.";
"postpred.help.input.grid.step2" = "En Actuacion, desliza a izquierda o derecha sobre la cuadricula de fotos. Los posts 1-9 corresponden a los digitos 1-9. Los posts 10, 11 y 12 corresponden al digito 0. Un indicador muestra el numero acumulado.";
"postpred.help.input.grid.step3" = "Pulsa el icono de Posts para confirmar y activar la revelacion.";
"postpred.help.input.ocr.label" = "OCR - RECONOCIMIENTO POR CAMARA";
"postpred.help.input.ocr.step1" = "Activa **OCR** en los ajustes de Post Prediction.";
"postpred.help.input.ocr.step2" = "Apunta la camara a cualquier palabra escrita a mano o impresa. La app la lee automaticamente y activa la revelacion correspondiente.";
"postpred.help.input.url.label" = "ESQUEMA URL";
"postpred.help.input.url.step1" = "Activa **URL Scheme** en los ajustes de Post Prediction.";
"postpred.help.input.url.step2" = "Activa la revelacion de forma remota mediante una URL personalizada, util con etiquetas NFC, codigos QR o accesos directos de automatizacion.";
"postpred.help.before.1" = "Crea un **Set** en la seccion Sets. Elige el tipo de letra (Numerico o Palabra) y selecciona una plantilla de imagen o sube tus propias fotos.";
"postpred.help.before.2" = "Sube las imagenes y espera a que sean **archivadas automaticamente**. Esto puede tardar varias horas, deja la app activa toda la noche si es necesario.";
"postpred.help.before.3" = "Durante la subida, **no uses la app**, no cambies de red ni interrumpas el proceso. La pantalla permanece encendida automaticamente. Una notificacion te avisara para que vuelvas entre cada subida.";
"postpred.help.before.4" = "Establece el Set subido como **activo** en los ajustes de Post Prediction.";
"postpred.help.before.5" = "Activa al menos un **metodo de entrada**: Cuadricula, OCR o URL Scheme.";
"postpred.help.during.step.invite" = "LA ELECCION LIBRE";
"postpred.help.during.invite.action" = "Pide al espectador que piense libremente en una palabra, numero o letra. No sugieras nada.";
"postpred.help.during.invite.dialogue" = "Piensa en cualquier palabra, o en cualquier numero. Algo personal, algo que solo tu sabes. No lo digas todavia.";
"postpred.help.during.step.input" = "CAPTURANDO LA ELECCION";
"postpred.help.during.input.action" = "Captura la entrada en silencio con Cuadricula, OCR o URL Scheme, mientras el espectador dice su eleccion en voz alta.";
"postpred.help.during.input.dialogue" = "Dilo en voz alta ahora, lo suficientemente alto para que todos escuchen.";
"postpred.help.during.step.reveal" = "LA REVELACION";
"postpred.help.during.reveal.action" = "La app desarchiva la foto correspondiente. En la app, el resultado aparece en 2-3 segundos. En Instagram real, cada foto se desarchiva de forma individual con una breve pausa, el tiempo total depende de la longitud de la palabra.";
"postpred.help.during.timing.action" = "Cuando la app vibra, la revelacion esta en vivo en Instagram real. Dirige al espectador para que abra Instagram.";
"postpred.help.during.timing.dialogue" = "Abre Instagram. Ve a mi perfil. Desplazate hacia abajo, siempre estuvo ahi.";
"postpred.help.tip.timing" = "**Velocidad de revelacion.** Una letra o digito: ~2-3 segundos. Cinco letras (p. ej. MAGIC): ~12-15 segundos. Cada letra adicional suma ~2-3 segundos.";
"postpred.help.tip.vibration" = "**Vibracion = listo.** El feedback haptico es la senal de que la foto esta en vivo en Instagram real. Una vez que vibra, dirige al espectador para que vea su perfil.";
"postpred.help.tip.position" = "**Posicion original.** La foto reaparece exactamente donde estaba en la cuadricula, con su fecha original. Puede ser necesario desplazarse para encontrarla.";
"postpred.help.tip.upload" = "**Durante la subida.** No uses la app, no cambies de red Wi-Fi ni bloquees la pantalla. Una notificacion te avisa para que vuelvas entre cada subida.";
"postpred.help.tip.banks" = "**Numero de Bancos.** Cada banco = una posicion de letra o digito. Planifica tus sets en funcion de la palabra o numero mas largo que quieras revelar.";
"postpred.help.tip.fakeapp" = "**Vista previa = instantánea, Instagram real = tras la vibración.** La predicción aparece en el perfil falso de la app en el momento en que se activa, pero aún no está disponible en Instagram real. Espera la vibración háptica antes de proceder.";
"postpred.help.tip.openprofile" = "**Abre tu perfil de Instagram real primero.** Tras la vibración que confirma la subida, abre tu propio perfil de Instagram antes de invitar al espectador a mirar. Esto carga el contenido en el feed; si el espectador refresca antes, puede que tenga que hacer scroll hacia abajo para verlo.";

// Set upload — progressive upload info banner
"set.upload.info.title"   = "Subida progresiva";
"set.upload.info.body"    = "La app subirá las fotos una a una manteniendo la pantalla activa. Si sales de la app, recibirás una notificación antes de cada subida para que puedas volver a tiempo.";
"set.upload.info.sleep"   = "Mantén la pantalla encendida y permanece en la app durante la subida.";
