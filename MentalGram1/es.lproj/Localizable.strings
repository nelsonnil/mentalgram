// ── Limits & Safety help (simplified) ──
"limits.help.title" = "Límites y seguridad";

"limits.help.calm.title" = "Tranquilo — está todo bajo control";
"limits.help.calm.body" = "Instagram muestra de vez en cuando un aviso breve pidiendo confirmar que eres tú. Es algo completamente normal en cualquier app conectada a la plataforma y no tiene nada que ver con un baneo. Vault está diseñada con las mismas medidas anti-bot que usan las apps reales, y cada una ha sido probada a fondo.";
"limits.help.calm.infobox" = "He provocado personalmente este tipo de aviso más de 100 veces durante el desarrollo y mi cuenta nunca ha sido baneada. Otras apps con el mismo enfoque funcionan sin problemas — si hubiera algún riesgo real, Vault no estaría publicada.";

"limits.help.warning.title" = "Si aparece un aviso de \"actividad inusual\"";
"limits.help.warning.intro" = "Tranquilo — no es un baneo. Es simplemente Instagram confirmando que eres tú. Sigue estos pasos:";
"limits.help.warning.step1" = "Abre la app oficial de Instagram y pulsa \"Dismiss\" en el aviso.";
"limits.help.warning.step2" = "Si pide verificación, complétala con el código de email o SMS.";
"limits.help.warning.step3" = "En Vault, cierra sesión desde Ajustes, espera un minuto y vuelve a iniciar sesión.";
"limits.help.warning.step4" = "Listo para continuar — tu cuenta está segura.";
"limits.help.warning.reassure" = "Tu cuenta sigue funcionando perfectamente. Esto solo pausa Vault unos minutos, nada más.";

"limits.help.show.title" = "Durante una actuación";
"limits.help.show.body" = "Si aparece un aviso mientras el espectador está mirando la pantalla, Vault oculta todos los detalles técnicos y muestra una pantalla genérica de \"Sin conexión a Internet\".";
"limits.help.show.infobox" = "Excusa perfecta: \"Uf, Instagram falla un momento, nada importante.\" Ningún espectador verá nada técnico.";

"limits.help.best.title" = "Buenas prácticas";
"limits.help.best.item1" = "No repitas el mismo efecto varias veces seguidas en la misma sesión — el algoritmo puede marcarlo como automatizado.";
"limits.help.best.item2" = "Prepara tus sets (Sync & Archive) la noche anterior o al menos una hora antes del show, no justo después de ensayar.";
"limits.help.best.item3" = "Si actúas con frecuencia, usa una cuenta de Instagram dedicada, separada de la principal.";
"limits.help.best.item4" = "Vault gestiona automáticamente todos los tiempos de espera — tú no tienes que pensar en nada.";

// ── Guide: Camouflage section ──
"guide.section.camouflage" = "CAMUFLAJE";

"guide.fakehome.title" = "Pantalla de inicio falsa";
"guide.fakehome.subtitle" = "Muestra una captura de pantalla del inicio al abrir Performance";
"guide.fakehome.help.what.title" = "¿Qué es la pantalla de inicio falsa?";
"guide.fakehome.help.what.body" = "Al abrir Performance, en lugar de ir directamente a tu perfil, la app muestra una captura de tu pantalla de inicio real. Para quien observe parecerá que acabas de abrir Instagram normalmente.";
"guide.fakehome.help.how.title" = "Cómo usarla";
"guide.fakehome.help.how.body" = "1. Haz una captura real de tu pantalla de inicio asegurándote de que el icono de Instagram sea visible.\n\n2. Súbela en Ajustes › Otros › Pantalla de inicio falsa.\n\n3. Activa el interruptor.\n\n4. La próxima vez que abras Performance aparecerá esa captura a pantalla completa — pulsa en cualquier lugar (idealmente sobre el icono de Instagram) para revelar tu perfil.";
"guide.fakehome.help.why.title" = "¿Por qué usarla?";
"guide.fakehome.help.why.body" = "Crea la ilusión de que simplemente estás abriendo la app real de Instagram. Quien mire tu pantalla solo verá la pantalla de inicio normal antes de que aparezca tu perfil, haciendo que la experiencia parezca completamente natural.";

"guide.lockscreen.title" = "Entrada por pantalla de bloqueo";
"guide.lockscreen.subtitle" = "Pantalla de bloqueo iOS falsa para introducir dígitos secretos";
"guide.lockscreen.help.what.title" = "¿Qué es la entrada por pantalla de bloqueo?";
"guide.lockscreen.help.what.body" = "Al abrir Performance, la app muestra una pantalla de código falsa al estilo iOS antes de revelar tu perfil. Para cualquier observador parecerá que simplemente estás desbloqueando el teléfono.";
"guide.lockscreen.help.how.title" = "Cómo introducir tu número secreto";
"guide.lockscreen.help.how.body" = "1. Pulsa los dígitos de tu número secreto en el teclado numérico — se registran en silencio.\n\n2. Pulsa en cualquier lugar fuera del teclado para bloquear esos dígitos.\n\n3. Rellena los puntos restantes pulsando cualquier dígito — se ignoran.\n\n4. Una vez llenos los 4 puntos, la pantalla de bloqueo se cierra y se abre Performance.";
"guide.lockscreen.help.wallpaper.title" = "Fondo de pantalla";
"guide.lockscreen.help.wallpaper.body" = "Sube el mismo fondo que usas en tu pantalla de bloqueo real para que la falsa sea idéntica. Sin fondo no se puede activar la entrada por pantalla de bloqueo.";
"guide.lockscreen.help.why.title" = "¿Por qué usarla?";
"guide.lockscreen.help.why.body" = "Disfraza el acto de introducir un número secreto como un desbloqueo normal del teléfono. Combinado con la pantalla de inicio falsa, la secuencia completa es: desbloquear teléfono → pantalla de inicio → abrir Instagram — completamente natural para cualquier observador.";
"guide.lockscreen.help.tricks.title" = "El mismo número secreto — muchos trucos";
"guide.lockscreen.help.tricks.body" = "El número que introduces aquí es el mismo número secreto usado por la entrada de cuadrícula y todos los demás trucos. Con él puedes activar:\n\n• Desarchivar una foto de un set numérico\n• Revelar una carta\n• Mostrar una imagen personalizada\n• Activar el efecto de contador\n• Forzar un reel en Explorar";
"guide.lockscreen.help.cards.title" = "Códigos de cartas";
"guide.lockscreen.help.cards.body" = "Para revelar una carta, introduce su código como número secreto:\n\nPalos:  1 = ♠   2 = ♥   3 = ♣   4 = ♦\n\nCartas A–9  →  [valor][palo]\n  A♠ = 11    7♥ = 72    9♦ = 94\n\nCartas 10, J, Q, K  →  [decena][unidad][palo]\n  10♠ = 101    J♥ = 112\n  Q♣  = 123    K♦  = 134\n\nEjemplo: para revelar Q♥ introduce 122.";
